---
/**
 * EXPERIMENT — cinematic, video-backed hero (currently used on /life).
 *
 * Ported from a streaming-hero reference prompt (full-bleed background video,
 * bottom-only frosted blur, liquid-glass buttons, staggered blur-fade-up
 * entrance). Adapted to this Astro site: no duplicate navbar (the site's
 * sticky <Nav> handles routing), in-page tall hero instead of a full-viewport
 * takeover so the page still scrolls, inline Lucide SVGs.
 *
 * The reference clip — two monolithic forms with sunset light pouring through
 * the gap, a path leading toward it — reads as a threshold / the long view,
 * which is why it landed on Life ("the slow lane is the long lane").
 *
 * Background video and poster are self-hosted under /public/landing/ (the
 * poster is a still frame from the video, so the poster→video hand-off is
 * seamless).
 *
 * Faithful black/white liquid-glass EXCEPT the primary CTA, rendered in the
 * site's lime so the hero doesn't read as a generic template.
 */
const VIDEO_SRC = '/landing/life-cine.mp4';
---

<section
  class="relative w-full min-h-[88vh] overflow-hidden bg-black border-b border-hairline flex flex-col"
  data-cine-hero
>
  <!-- Background video (z-0) — poster paints instantly + fallback. -->
  <video
    class="absolute inset-0 w-full h-full object-cover z-0"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/landing/life-cine-poster.jpg"
    aria-hidden="true"
    data-cine-video
  >
    <source src={VIDEO_SRC} type="video/mp4" />
  </video>

  <!-- Bottom-only frosted blur (z-10) — blur, no dark gradient. -->
  <div
    class="absolute inset-0 z-10 backdrop-blur-xl cine-bottom-blur pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <!-- Content, anchored to the bottom (z-20). -->
  <div class="relative z-20 flex-1 flex flex-col justify-end px-4 sm:px-6 md:px-12 pb-10 md:pb-16">
    <div class="max-w-3xl">
      <!-- Metadata row -->
      <div
        class="flex flex-wrap items-center gap-3 sm:gap-6 mb-6 md:mb-8 text-xs sm:text-sm text-white animate-blur-fade-up"
        style="animation-delay: 300ms"
      >
        <span class="inline-flex items-center gap-1.5 font-medium">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          The slow lane
        </span>
        <span class="inline-flex items-center gap-1.5 text-gray-200">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Ten years, nine chapters
        </span>
        <span class="inline-flex items-center gap-1.5 text-gray-200">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          Aotearoa
        </span>
      </div>

      <!-- Title -->
      <h1
        class="text-white font-normal text-3xl sm:text-5xl md:text-6xl lg:text-7xl mb-4 md:mb-6 animate-blur-fade-up"
        style="letter-spacing: -0.04em; animation-delay: 400ms"
      >
        Step Through. The Long View.
      </h1>

      <!-- Description -->
      <p
        class="text-base sm:text-lg md:text-xl text-gray-400 mb-6 md:mb-10 max-w-2xl animate-blur-fade-up"
        style="animation-delay: 500ms"
      >
        Writing the book, reading what doesn't trend, and the people in
        the room — ten years in New Zealand, observed slowly.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center gap-3 sm:gap-4">
        <a
          href="/life/book"
          class="inline-flex items-center gap-2 rounded-full font-semibold px-6 sm:px-8 py-2.5 sm:py-3 bg-lime text-canvas hover:scale-[1.04] transition-transform animate-blur-fade-up"
          style="animation-delay: 600ms"
        >
          Read the book
          <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="#more"
          class="inline-flex items-center gap-2 rounded-full font-medium px-6 sm:px-8 py-2.5 sm:py-3 text-white liquid-glass animate-blur-fade-up"
          style="animation-delay: 700ms"
        >
          Reading &amp; the room
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#more"
    class="absolute left-1/2 -translate-x-1/2 bottom-4 z-20 text-white/70 hover:text-white transition-colors animate-blur-fade-up"
    style="animation-delay: 900ms"
    aria-label="Scroll down"
  >
    <span class="cine-bob inline-flex">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </span>
  </a>
</section>

<script>
  // Respect reduced-motion: hold the video on its first frame.
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const v = document.querySelector<HTMLVideoElement>('[data-cine-video]');
    v?.removeAttribute('autoplay');
    v?.pause();
  }
</script>
