---
/**
 * Full-bleed hero `<picture>` for the AI-painted scenes in /public/landing/.
 *
 * Art-directed: mobile (<768px) gets a 1:1 centered square crop focused on
 * the main subject; desktop gets the wide 1536×944 scene. The host
 * `.hero-fullbleed` section uses matching aspect-ratio rules so the image
 * always fills exactly with no cover-crop guesswork.
 *
 * Each `name` must have these variants in /public/landing/ (generated by
 * scripts/optimize-images.mjs):
 *   <name>.avif / <name>.webp                     (1536×944 desktop)
 *   <name>-768w.avif / <name>-768w.webp           (downscaled desktop)
 *   <name>-1280w.avif / <name>-1280w.webp         (downscaled desktop)
 *   <name>-mobile.avif / <name>-mobile.webp       (944×944 mobile crop)
 */
export interface Props {
  /** Base filename in /public/landing/ (without extension). */
  name: string;
  /** Descriptive alt text for the painted scene. */
  alt: string;
  /** Image classes — defaults match the existing full-bleed positioning. */
  imgClass?: string;
}

const {
  name,
  alt,
  imgClass = 'absolute inset-0 w-full h-full object-cover select-none',
} = Astro.props;

const base = `/landing/${name}`;
const desktopAvif = `${base}-768w.avif 768w, ${base}-1280w.avif 1280w, ${base}.avif 1536w`;
const desktopWebp = `${base}-768w.webp 768w, ${base}-1280w.webp 1280w, ${base}.webp 1536w`;
---

<picture>
  <!-- Mobile (<768px): 1:1 square crop -->
  <source media="(max-width: 767px)" type="image/avif" srcset={`${base}-mobile.avif`} />
  <source media="(max-width: 767px)" type="image/webp" srcset={`${base}-mobile.webp`} />
  <!-- Desktop / tablet (≥768px): full 1536×944 scene -->
  <source type="image/avif" srcset={desktopAvif} sizes="100vw" />
  <source type="image/webp" srcset={desktopWebp} sizes="100vw" />
  <img
    src={`${base}.webp`}
    alt={alt}
    class={imgClass}
    draggable="false"
    fetchpriority="high"
    decoding="async"
  />
</picture>
