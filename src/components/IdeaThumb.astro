---
/* IdeaThumb — a generative, animated abstract geometric thumbnail for the
   /ideas article list. Pure SVG + CSS (no raster). Each article picks a
   `motif` + `accent` + `seed`; the seed deterministically varies geometry so
   no two cards look identical. Honors prefers-reduced-motion. */
export interface Props {
  motif?: 'orbit' | 'constellation' | 'bars' | 'spiral' | 'wave' | 'rings' | 'loop' | 'core' | 'team' | 'orchestrator' | 'ascent';
  accent?: string; // hex
  seed?: number;
  index?: string;  // optional corner label
}
const { motif = 'orbit', accent = '#9fe870', seed = 1, index } = Astro.props;

// Deterministic PRNG (mulberry-ish) from the seed.
function makeRand(s: number) {
  let x = (s * 2654435761) % 2147483647;
  if (x <= 0) x += 2147483646;
  return () => {
    x = (x * 16807) % 2147483647;
    return (x - 1) / 2147483646;
  };
}
const rand = makeRand(seed);
const rnd = (min: number, max: number) => min + rand() * (max - min);

const W = 220;
const H = 165;
const CX = W / 2;
const CY = H / 2;

// Unique id namespace so gradient/filter ids never collide across instances.
const uid = `it_${motif}_${seed}`;

// ── Precompute geometry per motif ──────────────────────────────────────────
// constellation: nodes + nearest-neighbour edges
const conNodes: { x: number; y: number; r: number; d: number }[] = [];
const conEdges: { x1: number; y1: number; x2: number; y2: number }[] = [];
if (motif === 'constellation') {
  const n = Math.round(rnd(5, 6)) + (seed % 5); // varied count
  const count = Math.max(4, Math.min(11, n));
  for (let i = 0; i < count; i++) {
    conNodes.push({ x: rnd(24, W - 24), y: rnd(20, H - 20), r: rnd(1.6, 3.4), d: rnd(0, 6) });
  }
  // connect each node to its 2 nearest neighbours
  for (let i = 0; i < conNodes.length; i++) {
    const dists = conNodes
      .map((p, j) => ({ j, d: (p.x - conNodes[i].x) ** 2 + (p.y - conNodes[i].y) ** 2 }))
      .filter((o) => o.j !== i)
      .sort((a, b) => a.d - b.d)
      .slice(0, 2);
    for (const o of dists) {
      if (o.j > i) conEdges.push({ x1: conNodes[i].x, y1: conNodes[i].y, x2: conNodes[o.j].x, y2: conNodes[o.j].y });
    }
  }
}

// orbit: concentric rings, each with a node riding it
const orbitRings = motif === 'orbit'
  ? [0, 1, 2].map((i) => ({
      rx: 30 + i * 24 + rnd(-4, 4),
      ry: (30 + i * 24) * rnd(0.6, 0.78),
      dur: 14 + i * 7,
      rev: i % 2 === 1,
      tilt: rnd(-25, 25),
      op: 0.5 - i * 0.1,
    }))
  : [];

// bars: ascending columns
const bars = motif === 'bars'
  ? Array.from({ length: 9 }, (_, i) => ({
      x: 22 + i * 19,
      h: rnd(28, 120),
      dur: rnd(2.6, 4.4),
      delay: -rnd(0, 3),
    }))
  : [];

// rings: overlapping circles (intimacy / connection)
const rings = motif === 'rings'
  ? Array.from({ length: 3 }, (_, i) => ({
      cx: CX + (i - 1) * rnd(22, 30),
      cy: CY + rnd(-8, 8),
      r: rnd(34, 46),
      dur: rnd(5, 8),
      delay: -i * 1.3,
    }))
  : [];

// spiral: archimedean spiral path
function spiralPath() {
  const turns = 3.2;
  const steps = 120;
  let d = '';
  for (let i = 0; i <= steps; i++) {
    const t = (i / steps) * turns * Math.PI * 2;
    const r = 4 + (i / steps) * 64;
    const x = CX + Math.cos(t) * r * 1.18;
    const y = CY + Math.sin(t) * r * 0.82;
    d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1) + ' ';
  }
  return d;
}
const spiralD = motif === 'spiral' ? spiralPath() : '';

// wave: stacked sine paths
function wavePath(yBase: number, amp: number, phase: number) {
  const steps = 36;
  let d = '';
  for (let i = 0; i <= steps; i++) {
    const x = (i / steps) * (W + 40) - 20;
    const y = yBase + Math.sin((i / steps) * Math.PI * 4 + phase) * amp;
    d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1) + ' ';
  }
  return d;
}
const waves = motif === 'wave'
  ? [0, 1, 2].map((i) => ({
      d: wavePath(CY + (i - 1) * 24, 14 - i * 2, i * 1.1 + seed),
      op: 0.7 - i * 0.18,
      dur: 7 + i * 2,
    }))
  : [];

// ── core: bespoke flagship composition (article #08) ───────────────────────
function ellipsePt(rx: number, ry: number, deg: number) {
  const a = (deg * Math.PI) / 180;
  return [CX + Math.cos(a) * rx, CY + Math.sin(a) * ry] as const;
}
function ellipseArc(rx: number, ry: number, a0: number, a1: number, steps = 30) {
  let d = '';
  for (let i = 0; i <= steps; i++) {
    const [x, y] = ellipsePt(rx, ry, a0 + ((a1 - a0) * i) / steps);
    d += (i === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1) + ' ';
  }
  return d;
}
function wedgePath(r: number, a0: number, a1: number) {
  const [x0, y0] = [CX + Math.cos((a0 * Math.PI) / 180) * r, CY + Math.sin((a0 * Math.PI) / 180) * r * 0.6];
  const [x1, y1] = [CX + Math.cos((a1 * Math.PI) / 180) * r, CY + Math.sin((a1 * Math.PI) / 180) * r * 0.6];
  return `M ${CX} ${CY} L ${x0.toFixed(1)} ${y0.toFixed(1)} A ${r} ${(r * 0.6).toFixed(1)} 0 0 1 ${x1.toFixed(1)} ${y1.toFixed(1)} Z`;
}
const coreParticles = motif === 'core'
  ? Array.from({ length: 16 }, () => ({
      x: rnd(8, W - 8), y: rnd(6, H - 6), r: rnd(0.6, 1.9),
      d: rnd(0, 6), dx: rnd(-7, 7), dy: rnd(-7, 7),
    }))
  : [];
const coreOrbits = motif === 'core'
  ? [
      { rx: 80, ry: 30, tilt: -26, dur: 24, rev: false },
      { rx: 56, ry: 62, tilt: 30, dur: 17, rev: true },
      { rx: 38, ry: 22, tilt: 76, dur: 12, rev: false },
    ]
  : [];
const cometRx = 80, cometRy = 30, cometTilt = -26;
const cometD = motif === 'core' ? ellipseArc(cometRx, cometRy, -95, 0) : '';
const cometTail = ellipsePt(cometRx, cometRy, -95);
const cometHead = ellipsePt(cometRx, cometRy, 0);
const sweepD = motif === 'core' ? wedgePath(98, -22, 16) : '';

// ── team: a few connected people forming a company (article #07) ───────────
const teamPeople = motif === 'team'
  ? [-90, 0, 90, 180].map((deg, i) => {
      const [x, y] = ellipsePt(58, 38, deg);
      return { x, y, d: i * 1.3 };
    })
  : [];
const teamLinks: { x1: number; y1: number; x2: number; y2: number; hub: boolean }[] = [];
if (motif === 'team') {
  for (let i = 0; i < teamPeople.length; i++) {
    const p = teamPeople[i];
    teamLinks.push({ x1: CX, y1: CY, x2: p.x, y2: p.y, hub: true });
    const q = teamPeople[(i + 1) % teamPeople.length];
    teamLinks.push({ x1: p.x, y1: p.y, x2: q.x, y2: q.y, hub: false });
  }
}

// ── orchestrator: hub + 4 agent satellites (article #05) ───────────────────
const orchAgents = motif === 'orchestrator'
  ? [-45, 45, 135, 225].map((deg, i) => {
      const [x, y] = ellipsePt(64, 42, deg);
      return { x, y, d: i * 1.1 };
    })
  : [];

// ── ascent: a climbing route + holds (article #04) ─────────────────────────
const ascentHolds = motif === 'ascent'
  ? Array.from({ length: 11 }, () => ({ x: rnd(14, W - 14), y: rnd(18, H - 14), r: rnd(1.3, 3), d: rnd(0, 5) }))
  : [];
const climbStart = [16, H - 16] as const;
const climbEnd = [W - 14, 16] as const;
const ascentWaypoints = [
  climbStart, [54, H - 44], [92, H - 66], [132, H - 100], [172, 40], climbEnd,
];
const ascentD = motif === 'ascent'
  ? ascentWaypoints.map((p, i) => (i ? 'L' : 'M') + p[0] + ' ' + p[1]).join(' ')
  : '';
---

<div class="ideathumb" data-motif={motif} style={`--accent:${accent};`}>
  <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <radialGradient id={`${uid}_bg`} cx="50%" cy="42%" r="75%">
        <stop offset="0%" stop-color={accent} stop-opacity="0.10" />
        <stop offset="55%" stop-color={accent} stop-opacity="0.02" />
        <stop offset="100%" stop-color="#000000" stop-opacity="0" />
      </radialGradient>
      <radialGradient id={`${uid}_glow`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color={accent} stop-opacity="0.9" />
        <stop offset="100%" stop-color={accent} stop-opacity="0" />
      </radialGradient>
      <linearGradient id={`${uid}_stroke`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color={accent} stop-opacity="0.95" />
        <stop offset="100%" stop-color={accent} stop-opacity="0.35" />
      </linearGradient>
      {(motif === 'core' || motif === 'orchestrator' || motif === 'ascent' || motif === 'team') && (
        <filter id={`${uid}_blur`} x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="2.4" />
        </filter>
      )}
      {motif === 'core' && (
        <>
          <linearGradient
            id={`${uid}_comet`}
            gradientUnits="userSpaceOnUse"
            x1={cometTail[0]} y1={cometTail[1]}
            x2={cometHead[0]} y2={cometHead[1]}
          >
            <stop offset="0%" stop-color={accent} stop-opacity="0" />
            <stop offset="72%" stop-color={accent} stop-opacity="0.45" />
            <stop offset="100%" stop-color={accent} stop-opacity="1" />
          </linearGradient>
          <radialGradient id={`${uid}_sweep`} gradientUnits="userSpaceOnUse" cx={CX} cy={CY} r="98">
            <stop offset="0%" stop-color={accent} stop-opacity="0.20" />
            <stop offset="100%" stop-color={accent} stop-opacity="0" />
          </radialGradient>
        </>
      )}
      {motif === 'ascent' && (
        <linearGradient
          id={`${uid}_path`}
          gradientUnits="userSpaceOnUse"
          x1={climbStart[0]} y1={climbStart[1]}
          x2={climbEnd[0]} y2={climbEnd[1]}
        >
          <stop offset="0%" stop-color={accent} stop-opacity="0.15" />
          <stop offset="100%" stop-color={accent} stop-opacity="0.95" />
        </linearGradient>
      )}
    </defs>

    <rect x="0" y="0" width={W} height={H} fill={`url(#${uid}_bg)`} />

    {motif === 'orbit' && (
      <g fill="none">
        {orbitRings.map((r) => (
          <g class={r.rev ? 'spin-rev' : 'spin'} style={`--dur:${r.dur}s; transform-origin:${CX}px ${CY}px;`}>
            <g transform={`rotate(${r.tilt} ${CX} ${CY})`}>
              <ellipse cx={CX} cy={CY} rx={r.rx} ry={r.ry} stroke={`url(#${uid}_stroke)`} stroke-width="1" opacity={r.op} />
              <circle cx={CX + r.rx} cy={CY} r="3" fill="var(--accent)" class="twinkle" />
            </g>
          </g>
        ))}
        <circle cx={CX} cy={CY} r="14" fill={`url(#${uid}_glow)`} class="breathe" />
        <circle cx={CX} cy={CY} r="3.4" fill="#fff" opacity="0.92" />
      </g>
    )}

    {motif === 'constellation' && (
      <g>
        <g stroke="var(--accent)" stroke-width="0.8" opacity="0.34">
          {conEdges.map((e) => (
            <line x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2} />
          ))}
        </g>
        {conNodes.map((p) => (
          <g class="float" style={`--dur:${(5 + p.d).toFixed(1)}s; --dx:${rnd(-5, 5).toFixed(1)}px; --dy:${rnd(-5, 5).toFixed(1)}px;`}>
            <circle cx={p.x} cy={p.y} r={p.r + 4} fill={`url(#${uid}_glow)`} opacity="0.5" />
            <circle cx={p.x} cy={p.y} r={p.r} fill="var(--accent)" class="twinkle" style={`--delay:-${p.d.toFixed(1)}s;`} />
          </g>
        ))}
      </g>
    )}

    {motif === 'bars' && (
      <g>
        {bars.map((b) => (
          <rect
            x={b.x}
            y={H - 18}
            width="11"
            height={b.h}
            rx="3"
            fill="var(--accent)"
            class="rise"
            style={`transform-origin:${b.x + 5.5}px ${H - 18}px; --dur:${b.dur}s; --delay:${b.delay}s; --op:${rnd(0.45, 0.95).toFixed(2)};`}
          />
        ))}
        <line x1="10" y1={H - 18} x2={W - 10} y2={H - 18} stroke="var(--accent)" stroke-width="1" opacity="0.4" />
      </g>
    )}

    {motif === 'rings' && (
      <g fill="none" stroke-width="1.4">
        {rings.map((r) => (
          <circle
            cx={r.cx}
            cy={r.cy}
            r={r.r}
            stroke="var(--accent)"
            class="pulse"
            style={`transform-origin:${r.cx}px ${r.cy}px; --dur:${r.dur}s; --delay:${r.delay}s;`}
          />
        ))}
        <circle cx={CX} cy={CY} r="4" fill="var(--accent)" class="breathe" />
      </g>
    )}

    {motif === 'spiral' && (
      <g class="spin" style={`--dur:36s; transform-origin:${CX}px ${CY}px;`}>
        <path d={spiralD} fill="none" stroke={`url(#${uid}_stroke)`} stroke-width="1.4" stroke-linecap="round" class="dash" />
        <circle cx={CX} cy={CY} r="3" fill="#fff" opacity="0.9" />
      </g>
    )}

    {motif === 'wave' && (
      <g fill="none" stroke-width="1.6" stroke-linecap="round">
        {waves.map((w) => (
          <path d={w.d} stroke="var(--accent)" opacity={w.op} class="flow" style={`--dur:${w.dur}s;`} />
        ))}
      </g>
    )}

    {motif === 'loop' && (
      <g fill="none">
        <ellipse cx={CX} cy={CY} rx="58" ry="40" stroke="var(--accent)" stroke-width="1.4" opacity="0.5" />
        <ellipse cx={CX} cy={CY} rx="42" ry="58" stroke="var(--accent)" stroke-width="1" opacity="0.28"
          stroke-dasharray="4 7" class="spin-rev" style={`--dur:24s; transform-origin:${CX}px ${CY}px;`} />
        <g class="spin" style={`--dur:9s; transform-origin:${CX}px ${CY}px;`}>
          <circle cx={CX + 58} cy={CY} r="11" fill={`url(#${uid}_glow)`} />
          <circle cx={CX + 58} cy={CY} r="3.6" fill="#fff" opacity="0.95" />
        </g>
        <circle cx={CX} cy={CY} r="14" fill={`url(#${uid}_glow)`} class="breathe" opacity="0.7" />
      </g>
    )}

    {motif === 'core' && (
      <g>
        {/* drifting fleet of particles (the ~200 background Claudes) */}
        {coreParticles.map((p) => (
          <g class="float" style={`--dur:${(5 + p.d).toFixed(1)}s; --dx:${p.dx}px; --dy:${p.dy}px;`}>
            <circle cx={p.x} cy={p.y} r={p.r} fill="var(--accent)" class="twinkle" style={`--delay:-${p.d.toFixed(1)}s;`} opacity="0.65" />
          </g>
        ))}

        {/* radar sweep — agents scanning Twitter / GitHub / Slack */}
        <g class="spin" style={`--dur:11s; transform-origin:${CX}px ${CY}px;`}>
          <path d={sweepD} fill={`url(#${uid}_sweep)`} />
        </g>

        {/* outer dashed plane */}
        <ellipse cx={CX} cy={CY} rx="92" ry="55" fill="none" stroke="var(--accent)" stroke-width="1"
          opacity="0.14" stroke-dasharray="2 9" class="spin-rev" style={`--dur:44s; transform-origin:${CX}px ${CY}px;`} />

        {/* three tilted orbit loops, each carrying an agent node */}
        {coreOrbits.map((o) => (
          <g class={o.rev ? 'spin-rev' : 'spin'} style={`--dur:${o.dur}s; transform-origin:${CX}px ${CY}px;`}>
            <g transform={`rotate(${o.tilt} ${CX} ${CY})`}>
              <ellipse cx={CX} cy={CY} rx={o.rx} ry={o.ry} fill="none" stroke={`url(#${uid}_stroke)`} stroke-width="1" opacity="0.42" />
              <circle cx={CX + o.rx} cy={CY} r="2.6" fill="var(--accent)" class="twinkle" />
            </g>
          </g>
        ))}

        {/* comet sweeping the main loop */}
        <g class="spin" style={`--dur:7s; transform-origin:${CX}px ${CY}px;`}>
          <g transform={`rotate(${cometTilt} ${CX} ${CY})`}>
            <path d={cometD} fill="none" stroke={`url(#${uid}_comet)`} stroke-width="2.4" stroke-linecap="round" />
            <circle cx={cometHead[0]} cy={cometHead[1]} r="9" fill={`url(#${uid}_glow)`} filter={`url(#${uid}_blur)`} />
            <circle cx={cometHead[0]} cy={cometHead[1]} r="3" fill="#fff" />
          </g>
        </g>

        {/* the core — model / values */}
        <circle cx={CX} cy={CY} r="24" fill={`url(#${uid}_glow)`} class="breathe" />
        <circle cx={CX} cy={CY} r="11" fill="none" stroke="var(--accent)" stroke-width="1.2" opacity="0.55"
          class="pulse" style={`transform-origin:${CX}px ${CY}px; --dur:4s;`} />
        <circle cx={CX} cy={CY} r="5.5" fill="var(--accent)" filter={`url(#${uid}_blur)`} />
        <circle cx={CX} cy={CY} r="3.3" fill="#fff" />
      </g>
    )}

    {motif === 'team' && (
      <g>
        {/* the company — a soft enclosing boundary */}
        <ellipse cx={CX} cy={CY} rx="86" ry="58" fill="none" stroke="var(--accent)" stroke-width="1"
          opacity="0.16" stroke-dasharray="2 10" class="spin-rev" style={`--dur:50s; transform-origin:${CX}px ${CY}px;`} />
        {/* links between people + to the shared hub */}
        <g stroke="var(--accent)">
          {teamLinks.map((l) => (
            <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} stroke-width={l.hub ? 0.8 : 1} opacity={l.hub ? 0.22 : 0.4} />
          ))}
        </g>
        {/* data packets pulsing out from the hub */}
        {teamLinks.filter((l) => l.hub).map((l, i) => (
          <g class="packet" style={`--dx:${(l.x2 - l.x1).toFixed(1)}px; --dy:${(l.y2 - l.y1).toFixed(1)}px; --dur:${(2.6 + i * 0.4).toFixed(1)}s;`}>
            <circle cx={l.x1} cy={l.y1} r="1.8" fill="var(--accent)" />
          </g>
        ))}
        {/* the few people, each amplified by a small agent satellite */}
        {teamPeople.map((p) => (
          <g class="float" style={`--dx:${((p.x - CX) * 0.08).toFixed(1)}px; --dy:${((p.y - CY) * 0.08).toFixed(1)}px; --dur:${(5 + p.d).toFixed(1)}s;`}>
            <circle cx={p.x} cy={p.y} r="9" fill={`url(#${uid}_glow)`} opacity="0.6" />
            <circle cx={p.x} cy={p.y} r="4" fill="var(--accent)" filter={`url(#${uid}_blur)`} />
            <circle cx={p.x} cy={p.y} r="2.4" fill="#fff" />
            <g class="spin" style={`--dur:${(6 + p.d).toFixed(1)}s; transform-origin:${p.x}px ${p.y}px;`}>
              <circle cx={p.x + 11} cy={p.y} r="1.6" fill="var(--accent)" class="twinkle" />
            </g>
          </g>
        ))}
        <circle cx={CX} cy={CY} r="3" fill="var(--accent)" opacity="0.7" class="breathe" />
      </g>
    )}

    {motif === 'orchestrator' && (
      <g>
        <ellipse cx={CX} cy={CY} rx="86" ry="56" fill="none" stroke="var(--accent)" stroke-width="1"
          opacity="0.14" stroke-dasharray="2 9" class="spin-rev" style={`--dur:46s; transform-origin:${CX}px ${CY}px;`} />
        {/* the orchestrating hub-and-spoke system, slowly turning */}
        <g class="spin" style={`--dur:54s; transform-origin:${CX}px ${CY}px;`}>
          <g stroke="var(--accent)" stroke-width="1" opacity="0.3">
            {orchAgents.map((s) => (<line x1={CX} y1={CY} x2={s.x} y2={s.y} />))}
          </g>
          {orchAgents.map((s, i) => (
            <g class="packet" style={`--dx:${(s.x - CX).toFixed(1)}px; --dy:${(s.y - CY).toFixed(1)}px; --dur:${(2.4 + i * 0.3).toFixed(1)}s;`}>
              <circle cx={CX} cy={CY} r="1.8" fill="var(--accent)" />
            </g>
          ))}
          {orchAgents.map((s) => (
            <g>
              <circle cx={s.x} cy={s.y} r="8" fill={`url(#${uid}_glow)`} opacity="0.5" />
              <rect x={s.x - 4} y={s.y - 4} width="8" height="8" fill="var(--accent)"
                transform={`rotate(45 ${s.x} ${s.y})`} class="twinkle" style={`--delay:-${s.d.toFixed(1)}s;`} />
            </g>
          ))}
        </g>
        {/* central orchestrator */}
        <circle cx={CX} cy={CY} r="20" fill={`url(#${uid}_glow)`} class="breathe" />
        <circle cx={CX} cy={CY} r="10" fill="none" stroke="var(--accent)" stroke-width="1.2" opacity="0.5"
          class="pulse" style={`transform-origin:${CX}px ${CY}px; --dur:4s;`} />
        <circle cx={CX} cy={CY} r="5" fill="var(--accent)" filter={`url(#${uid}_blur)`} />
        <circle cx={CX} cy={CY} r="3" fill="#fff" />
      </g>
    )}

    {motif === 'ascent' && (
      <g>
        {/* level lines — 30 / 60 / 90 */}
        <g stroke="var(--accent)" stroke-width="1" opacity="0.10">
          <line x1="8" y1={(H * 0.34).toFixed(0)} x2={W - 8} y2={(H * 0.34).toFixed(0)} stroke-dasharray="3 7" />
          <line x1="8" y1={(H * 0.58).toFixed(0)} x2={W - 8} y2={(H * 0.58).toFixed(0)} stroke-dasharray="3 7" />
          <line x1="8" y1={(H * 0.8).toFixed(0)} x2={W - 8} y2={(H * 0.8).toFixed(0)} stroke-dasharray="3 7" />
        </g>
        {/* climbing-wall holds */}
        {ascentHolds.map((h) => (
          <circle cx={h.x} cy={h.y} r={h.r} fill="var(--accent)" opacity="0.45" class="twinkle" style={`--delay:-${h.d.toFixed(1)}s;`} />
        ))}
        {/* the route */}
        <path d={ascentD} fill="none" stroke={`url(#${uid}_path)`} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        {/* the climber, ascending on a loop */}
        <g class="packet" style={`--dx:${(climbEnd[0] - climbStart[0]).toFixed(1)}px; --dy:${(climbEnd[1] - climbStart[1]).toFixed(1)}px; --dur:6s;`}>
          <circle cx={climbStart[0]} cy={climbStart[1]} r="9" fill={`url(#${uid}_glow)`} filter={`url(#${uid}_blur)`} />
          <circle cx={climbStart[0]} cy={climbStart[1]} r="3.2" fill="#fff" />
        </g>
      </g>
    )}
  </svg>
  {index && <span class="ideathumb__idx">{index}</span>}
</div>

<style>
  .ideathumb {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 100% at 50% 0%, #1d1f1a 0%, #131410 60%, #0e0f0c 100%);
    overflow: hidden;
  }
  .ideathumb svg { width: 100%; height: 100%; display: block; }
  .ideathumb__idx {
    position: absolute;
    bottom: 7px;
    right: 11px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45);
  }

  .spin { animation: it-spin var(--dur, 20s) linear infinite; }
  .spin-rev { animation: it-spin var(--dur, 20s) linear infinite reverse; }
  .float { animation: it-float var(--dur, 6s) ease-in-out infinite alternate; }
  .twinkle { animation: it-twinkle 3.2s ease-in-out infinite; animation-delay: var(--delay, 0s); }
  .breathe { animation: it-breathe 4s ease-in-out infinite; }
  .rise { animation: it-rise var(--dur, 3s) ease-in-out infinite alternate; animation-delay: var(--delay, 0s); transform: scaleY(0.15); opacity: var(--op, 0.7); }
  .pulse { animation: it-pulse var(--dur, 6s) ease-in-out infinite; animation-delay: var(--delay, 0s); }
  .dash { stroke-dasharray: 5 9; animation: it-dash 8s linear infinite; }
  .flow { animation: it-flow var(--dur, 8s) linear infinite; }
  .packet { animation: it-packet var(--dur, 3s) linear infinite; }

  @keyframes it-spin { to { transform: rotate(360deg); } }
  @keyframes it-float { from { transform: translate(0, 0); } to { transform: translate(var(--dx, 4px), var(--dy, 4px)); } }
  @keyframes it-twinkle { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  @keyframes it-breathe { 0%, 100% { transform: scale(0.85); opacity: 0.75; } 50% { transform: scale(1.12); opacity: 1; } }
  @keyframes it-rise { from { transform: scaleY(0.15); } to { transform: scaleY(1); } }
  @keyframes it-pulse { 0%, 100% { transform: scale(0.92); opacity: 0.35; } 50% { transform: scale(1.06); opacity: 0.8; } }
  @keyframes it-dash { to { stroke-dashoffset: -140; } }
  @keyframes it-flow { from { transform: translateX(0); } to { transform: translateX(-40px); } }
  @keyframes it-packet {
    0% { transform: translate(0, 0); opacity: 0; }
    12% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translate(var(--dx, 0), var(--dy, 0)); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ideathumb * { animation: none !important; }
    .rise { transform: scaleY(0.7); }
  }
</style>
