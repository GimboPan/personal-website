---
/**
 * Reusable pixel-art Claude Code penguin that waddles back and forth
 * across the bottom of its positioned parent. Renders as an absolutely
 * positioned overlay (inset: 0; pointer-events: none) so it can be
 * dropped into any card/scene without disturbing layout.
 *
 * The parent must be `position: relative` (or otherwise establish a
 * containing block) and should usually have `overflow: hidden`.
 */
export interface Props {
  /** Sprite pixel size (square). Default 56. */
  size?: number;
  /** Accent color used for the lime "C" on the penguin's belly. */
  accent?: string;
  /** Edge padding the character reverses at. Default 10. */
  padding?: number;
  /** Walk-loop duration (CSS time string). Default 9s. */
  walkDuration?: string;
  /** Offset from the parent's bottom edge. Default 0. */
  bottomOffset?: number;
  /**
   * Movement behavior:
   *  - 'walk': straight back-and-forth (default)
   *  - 'walk-look': walk to one end, pause and look both ways, walk
   *    back, repeat. Useful for slower, more lifelike ambient mascots.
   *  - 'snail': very slow waddle with two mid-walk pauses per loop;
   *    during each pause the eyes drift upward as if looking at the sky.
   */
  behavior?: 'walk' | 'walk-look' | 'snail';
  /**
   * Optional CSS animation-delay (e.g. '-4s'). Negative delays start
   * the character mid-cycle — useful to desynchronize multiple
   * mascots that share a parent.
   */
  delay?: string;
}

const {
  size = 56,
  accent = '#9fe870',
  padding = 10,
  walkDuration = '9s',
  bottomOffset = 0,
  behavior = 'walk',
  delay = '0s',
} = Astro.props;

const styleVars = [
  `--mascot-size: ${size}px`,
  `--mascot-accent: ${accent}`,
  `--mascot-pad: ${padding}px`,
  `--mascot-walk-dur: ${walkDuration}`,
  `--mascot-bottom: ${bottomOffset}px`,
  `--mascot-delay: ${delay}`,
].join('; ');
---

<div
  class:list={['pixel-mascot', `pixel-mascot--${behavior}`]}
  style={styleVars}
  aria-hidden="true"
>
  <div class="pixel-mascot__walker">
    <div class="pixel-mascot__shadow"></div>
    <div class="pixel-mascot__bobber">
      <!-- Frame 1 — left leg grounded, right leg lifted -->
      <svg
        class="pixel-mascot__frame pixel-mascot__frame--1"
        viewBox="0 0 16 20"
        shape-rendering="crispEdges"
      >
        <!-- body main block (cols 4-11, rows 3-14) -->
        <rect x="4" y="3" width="8" height="12" fill="#d97757"/>
        <!-- arm stubs sticking out (1 col each side) -->
        <rect x="3" y="9" width="1" height="2" fill="#d97757"/>
        <rect x="12" y="9" width="1" height="2" fill="#d97757"/>
        <!-- eyes: 1x2 vertical black rectangles, grouped so a CSS
             animation can translate them up during a "look up" pause -->
        <g class="pixel-mascot__eyes">
          <rect x="5" y="5" width="1" height="2" fill="#0e0f0c"/>
          <rect x="10" y="5" width="1" height="2" fill="#0e0f0c"/>
        </g>
        <!-- legs: left grounded (3 rows), right lifted (2 rows) -->
        <rect x="4" y="15" width="2" height="3" fill="#d97757"/>
        <rect x="10" y="15" width="2" height="2" fill="#d97757"/>
      </svg>

      <!-- Frame 2 — right leg grounded, left leg lifted -->
      <svg
        class="pixel-mascot__frame pixel-mascot__frame--2"
        viewBox="0 0 16 20"
        shape-rendering="crispEdges"
      >
        <!-- body main block (cols 4-11, rows 3-14) -->
        <rect x="4" y="3" width="8" height="12" fill="#d97757"/>
        <!-- arm stubs sticking out -->
        <rect x="3" y="9" width="1" height="2" fill="#d97757"/>
        <rect x="12" y="9" width="1" height="2" fill="#d97757"/>
        <!-- eyes (grouped for look-up animation) -->
        <g class="pixel-mascot__eyes">
          <rect x="5" y="5" width="1" height="2" fill="#0e0f0c"/>
          <rect x="10" y="5" width="1" height="2" fill="#0e0f0c"/>
        </g>
        <!-- legs: left lifted (2 rows), right grounded (3 rows) -->
        <rect x="4" y="15" width="2" height="2" fill="#d97757"/>
        <rect x="10" y="15" width="2" height="3" fill="#d97757"/>
      </svg>
    </div>
  </div>
</div>
