---
export interface Props {
  index: string;
  kicker: string;
  title: string;
  subtitle: string;
  /** Tailwind classes for the gradient/tint band behind the hero */
  bandClass?: string;
}

const { index, kicker, title, subtitle, bandClass = '' } = Astro.props;
---

<section class={`relative overflow-hidden ${bandClass}`}>
  <div class="pixel-stars opacity-40"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-6 lg:px-12 py-16 md:py-28 lg:py-32">
    <div class="flex flex-wrap items-center gap-2 sm:gap-3 terminal mb-5 md:mb-6">
      <span class="text-lime">{index}</span>
      <span class="text-ink-gray">//</span>
      <span class="text-ink-mint uppercase tracking-[0.1em] sm:tracking-tool break-words">{kicker}</span>
    </div>

    <h1
      class="display-mega text-ink-white text-4xl sm:text-5xl md:text-7xl lg:text-8xl max-w-4xl break-words"
    >
      {title}
    </h1>

    <p class="mt-5 md:mt-6 text-base md:text-lg text-ink-mint max-w-2xl leading-relaxed">
      {subtitle}
    </p>
  </div>
</section>
