---
/**
 * Full-bleed galaxy backdrop.
 * Layers (bottom → top):
 *  1. Deep cosmos radial gradient
 *  2. Diagonal milky way band
 *  3. Two nebula blobs (purple + green)
 *  4. Pixel star field (static, large)
 *  5. Pixel star field (twinkling, smaller)
 *  6. A distant planet ring on the horizon
 */
---

<div class="galaxy-root absolute inset-0 overflow-hidden" aria-hidden="true">
  <!-- 1. Deep cosmos -->
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(ellipse 90% 60% at 50% 30%, #1a1240 0%, #0d0a2c 25%, #08081a 55%, #0e0f0c 100%);"
  >
  </div>

  <!-- 2. Milky way band (diagonal, soft) -->
  <div
    class="absolute -inset-32"
    style="background:
      linear-gradient(
        110deg,
        transparent 35%,
        rgba(159,232,112,0.04) 42%,
        rgba(180,140,255,0.10) 50%,
        rgba(255,160,200,0.06) 58%,
        transparent 65%
      );
      filter: blur(6px);"
  >
  </div>

  <!-- 3a. Purple nebula -->
  <div
    class="absolute"
    style="left: 60%; top: 10%; width: 480px; height: 480px;
      background: radial-gradient(circle, rgba(155,90,200,0.28) 0%, rgba(155,90,200,0) 70%);
      filter: blur(20px);"
  >
  </div>

  <!-- 3b. Lime nebula -->
  <div
    class="absolute"
    style="left: 5%; top: 40%; width: 520px; height: 520px;
      background: radial-gradient(circle, rgba(159,232,112,0.10) 0%, rgba(159,232,112,0) 70%);
      filter: blur(24px);"
  >
  </div>

  <!-- 3c. Magenta deep -->
  <div
    class="absolute"
    style="left: 30%; top: 65%; width: 600px; height: 400px;
      background: radial-gradient(ellipse, rgba(255,80,150,0.10) 0%, rgba(255,80,150,0) 70%);
      filter: blur(30px);"
  >
  </div>

  <!-- 4. Static pixel stars (dense) -->
  <div class="absolute inset-0 stars-static"></div>

  <!-- 5. Twinkling pixel stars -->
  <div class="absolute inset-0 stars-twinkle-a"></div>
  <div class="absolute inset-0 stars-twinkle-b"></div>

  <!-- 6. A few oversized "anchor" stars for depth -->
  <div class="absolute inset-0 stars-bright"></div>

  <!-- 7. Distant planet (top right) -->
  <div
    class="absolute hidden md:block"
    style="right: 8%; top: 12%;"
  >
    <svg width="80" height="80" viewBox="0 0 32 32" class="pixelated opacity-70">
      <!-- planet body -->
      <circle cx="16" cy="16" r="10" fill="#9b5ac8" />
      <!-- bands -->
      <rect x="6" y="13" width="20" height="2" fill="#6a3d8e" />
      <rect x="6" y="17" width="20" height="1" fill="#7a4ba0" />
      <rect x="8" y="20" width="16" height="2" fill="#6a3d8e" />
      <!-- highlight -->
      <rect x="11" y="9" width="3" height="1" fill="#cdffad" opacity="0.6" />
      <!-- ring -->
      <ellipse cx="16" cy="16" rx="14" ry="3" fill="none" stroke="#9fe870" stroke-width="0.5" opacity="0.4" />
    </svg>
  </div>
</div>

<style>
  /* Static dense star layer */
  .stars-static {
    background-image:
      radial-gradient(1px 1px at 13% 7%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 27% 22%, #e2f6d5 50%, transparent 50%),
      radial-gradient(1px 1px at 42% 12%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 56% 30%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 71% 9%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 85% 27%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 92% 60%, #e2f6d5 50%, transparent 50%),
      radial-gradient(1px 1px at 8% 75%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 22% 88%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 37% 70%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 49% 92%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 64% 81%, #e2f6d5 50%, transparent 50%),
      radial-gradient(1px 1px at 78% 65%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 17% 50%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 91% 42%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 35% 38%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 60% 50%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 80% 90%, #ffffff 50%, transparent 50%);
    background-size: 100% 100%;
    image-rendering: pixelated;
  }

  /* Twinkle layer A — faster cycle */
  .stars-twinkle-a {
    background-image:
      radial-gradient(1px 1px at 19% 14%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 53% 18%, #9fe870 50%, transparent 50%),
      radial-gradient(1px 1px at 77% 38%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 30% 62%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 67% 78%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 14% 35%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 88% 70%, #ffffff 50%, transparent 50%);
    background-size: 100% 100%;
    image-rendering: pixelated;
    animation: twinkle 2.4s ease-in-out infinite;
  }

  /* Twinkle layer B — slower, offset */
  .stars-twinkle-b {
    background-image:
      radial-gradient(1px 1px at 45% 8%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 5% 22%, #9fe870 50%, transparent 50%),
      radial-gradient(1px 1px at 73% 55%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 26% 80%, #e2f6d5 50%, transparent 50%),
      radial-gradient(1px 1px at 95% 18%, #ffffff 50%, transparent 50%);
    background-size: 100% 100%;
    image-rendering: pixelated;
    animation: twinkle 4.2s ease-in-out infinite;
    animation-delay: -1.2s;
  }

  /* Bright anchor stars (2px) with subtle glow */
  .stars-bright {
    background-image:
      radial-gradient(2px 2px at 12% 18%, #ffffff 50%, transparent 50%),
      radial-gradient(2px 2px at 88% 32%, #cdffad 50%, transparent 50%),
      radial-gradient(2px 2px at 40% 55%, #ffffff 50%, transparent 50%),
      radial-gradient(2px 2px at 20% 85%, #9fe870 50%, transparent 50%),
      radial-gradient(2px 2px at 70% 88%, #ffffff 50%, transparent 50%);
    background-size: 100% 100%;
    image-rendering: pixelated;
    filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.5));
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }
</style>
