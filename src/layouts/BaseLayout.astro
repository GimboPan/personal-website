---
import '~/styles/globals.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  /** Hide the global CRT overlay (e.g. for full-bleed landing) */
  hideCrt?: boolean;
  /** Hide the HTML nav (e.g. landing has a baked-in painted nav inside the image) */
  hideNav?: boolean;
  /** Override OG image (relative to site, e.g. /og-image.jpg) */
  ogImage?: string;
}

const {
  title = "Gimbo's Universe",
  description = 'Work · Invest · Move · Live — a meaningful life in the future. A personal hub aggregating projects across the agentic era.',
  hideCrt = false,
  hideNav = false,
  ogImage = '/og-image.jpg',
} = Astro.props;

// Site origin — fall back to a placeholder pre-deploy.
// Astro picks up `site` from astro.config.mjs once configured for production.
const site = Astro.site?.toString() ?? 'https://gimbosuniverse.com/';
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gimbo (Pan Junbao)',
  alternateName: 'Gimbo',
  url: site,
  email: 'mailto:panjunbao@gmail.com',
  jobTitle: 'Supply Planner',
  worksFor: { '@type': 'Organization', name: 'ParagonCare REM Systems' },
  homeLocation: { '@type': 'Place', name: 'Auckland, New Zealand' },
  knowsAbout: [
    'Supply chain planning',
    'AI agents',
    'Tennis',
    'Investing',
    'Writing',
  ],
  sameAs: [],
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e0f0c" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Gimbo's Universe" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Three floating islands in deep space — work, fitness, life — Gimbo's Universe" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD: Person schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />

    <!-- Fonts: preconnect + non-blocking with font-display: swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=JetBrains+Mono:wght@400;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=JetBrains+Mono:wght@400;600&display=swap"
    />
    <!-- Pixel + retro display fonts loaded async (only used on landing) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
      media="print"
      onload="this.media='all'"
    />
  </head>
  <body class="bg-canvas text-ink-mint min-h-screen">
    {!hideNav && <Nav />}

    <main class="relative">
      <slot />
    </main>

    <Footer />

    {!hideCrt && (
      <>
        <div class="crt-overlay" aria-hidden="true"></div>
        <div class="crt-beam" aria-hidden="true"></div>
      </>
    )}
  </body>
</html>
