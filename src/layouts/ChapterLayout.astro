---
import BaseLayout from '~/layouts/BaseLayout.astro';

/* Layout for individual book chapter pages.
   Chapter .md files in src/pages/life/book/ point to this via frontmatter. */
interface Props {
  frontmatter: {
    chapterNum: string;
    zh: string;
    en: string;
    subtitle: string;
    draftDate: string;
    draftVersion: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={`${frontmatter.en} · ${frontmatter.zh} — Life Essentials`}
  description={frontmatter.subtitle}
  ogImage="/og-life.jpg"
>
  <header class="border-b border-hairline">
    <div class="mx-auto max-w-3xl px-6 lg:px-12 py-12 md:py-16">
      <a
        href="/life/book"
        class="inline-flex items-center gap-2 font-mono text-[11px] tracking-tool text-ink-gray hover:text-lime transition-colors mb-6"
      >
        ← table of contents
      </a>
      <div class="terminal text-lime mb-3 text-[11px]">
        Chapter {frontmatter.chapterNum} · {frontmatter.draftVersion} · {frontmatter.draftDate}
      </div>
      <h1
        class="font-display text-3xl md:text-5xl font-black text-ink-white leading-tight uppercase tracking-tight"
      >
        {frontmatter.en}
      </h1>
      <p class="mt-3 text-xl md:text-2xl text-ink-mint">{frontmatter.zh}</p>
      <p class="mt-5 text-base md:text-lg text-ink-gray italic leading-relaxed">
        {frontmatter.subtitle}
      </p>
    </div>
  </header>

  <article class="prose mx-auto max-w-3xl px-6 lg:px-12 py-12 md:py-16">
    <slot />
  </article>

  <footer class="border-t border-hairline">
    <div
      class="mx-auto max-w-3xl px-6 lg:px-12 py-10 flex items-center justify-between"
    >
      <a
        href="/life/book"
        class="font-mono text-[11px] tracking-tool text-ink-gray hover:text-lime transition-colors"
      >
        ← table of contents
      </a>
      <a
        href="/life"
        class="font-mono text-[11px] tracking-tool text-ink-gray hover:text-lime transition-colors"
      >
        /life →
      </a>
    </div>
  </footer>
</BaseLayout>
