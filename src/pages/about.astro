---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Gimbo's Universe"
  description="Who is Gimbo. Five roles, one person, ten years in New Zealand — the operator behind the universe."
  hideNav={true}
>
  <!-- ============ HERO: full-bleed AI image (the entire page) ============ -->
  <section
    class="relative w-full overflow-hidden"
    style="height: min(100vh, calc(100vw * 2 / 3));"
  >
    <img
      src="/landing/about-hero.png"
      alt="About — silhouette of a figure standing under a giant sculpted head dissolving into voxel architecture, framed by the bilingual five roles and life creed panels"
      class="absolute inset-0 w-full h-full object-cover select-none"
      style="object-position: center top;"
      draggable="false"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Top-nav baked-in text hot spots (mirrors the painted nav inside the image) -->
    <a href="/" aria-label="Gimbo's Universe (home)"
       class="absolute" style="top: 1.5%; left: 1.5%; width: 16%; height: 5%;"></a>
    <a href="/work" aria-label="AI X / Work"
       class="absolute" style="top: 2.5%; left: 60%; width: 6%; height: 3.5%;"></a>
    <a href="/fitness" aria-label="Fitness"
       class="absolute" style="top: 2.5%; left: 67%; width: 7%; height: 3.5%;"></a>
    <a href="/life" aria-label="Life"
       class="absolute" style="top: 2.5%; left: 75%; width: 4%; height: 3.5%;"></a>
    <a href="/ideas" aria-label="Ideas"
       class="absolute" style="top: 2.5%; left: 80%; width: 5%; height: 3.5%;"></a>
    <a href="/about" aria-label="About"
       class="absolute" style="top: 2.5%; left: 86%; width: 6%; height: 3.5%;"></a>
  </section>
</BaseLayout>
