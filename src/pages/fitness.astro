---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';
---

<BaseLayout
  title="Fitness — Gimbo's Universe"
  description="On the court I am present. The body is the one project I can't delegate — tennis, nutrition, strength."
  hideNav={true}
>
  <!-- ============ HERO: full-bleed AI image ============ -->
  <section
    class="relative w-full overflow-hidden border-b border-hairline"
    style="height: min(100vh, calc(100vw * 2 / 3));"
  >
    <img
      src="/landing/fitness-hero.png"
      alt="Fitness — back-view silhouette of a tennis player on an empty terracotta clay court at dusk, racquet at their side"
      class="absolute inset-0 w-full h-full object-cover select-none"
      style="object-position: center top;"
      draggable="false"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Top-nav baked-in text hot spots (mirrors the painted nav inside the image) -->
    <a href="/" aria-label="Gimbo's Universe (home)"
       class="absolute" style="top: 1.5%; left: 1.5%; width: 16%; height: 5%;"></a>
    <a href="/work" aria-label="AI X / Work"
       class="absolute" style="top: 2.5%; left: 60%; width: 6%; height: 3.5%;"></a>
    <a href="/fitness" aria-label="Fitness"
       class="absolute" style="top: 2.5%; left: 67%; width: 7%; height: 3.5%;"></a>
    <a href="/life" aria-label="Life"
       class="absolute" style="top: 2.5%; left: 75%; width: 4%; height: 3.5%;"></a>
    <a href="/ideas" aria-label="Ideas"
       class="absolute" style="top: 2.5%; left: 80%; width: 5%; height: 3.5%;"></a>
    <a href="/about" aria-label="About"
       class="absolute" style="top: 2.5%; left: 86%; width: 6%; height: 3.5%;"></a>
  </section>

  <section class="relative">
    <!-- subtle clay band -->
    <div
      class="absolute inset-0 -z-10"
      style="background: linear-gradient(180deg, #0e0f0c 0%, #15110d 60%, #0e0f0c 100%);"
    >
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Modules
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // body × 3
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Tennis Buddy"
          subtitle="Match logs, hitting partners, drill notes, NTRP-tagged sessions. A small Roland-Garros-themed app for finding and tracking court time."
          status="wip"
          tools={["MUI", "RG-design", "Match Log"]}
          featured={true}
        />
        <ModuleCard
          index="02"
          title="Nutrition · 营养"
          subtitle="What I eat, when, and why. Tracking intake against training load, NZ-grocery realities, and the long game (not the next 6-pack)."
          status="planned"
          tools={["MyFitnessPal", "Markdown"]}
        />
        <ModuleCard
          index="03"
          title="Strength · 力量训练"
          subtitle="Compound lifts, mobility work, recovery protocols. Volume tracking and progression as a hedge against everything tennis breaks down."
          status="planned"
          tools={["Apple Health", "Whoop"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
