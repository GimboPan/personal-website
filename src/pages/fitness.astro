---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';
import HeroSection from '~/components/HeroSection.astro';
import ClaudeCodeMascotCard from '~/components/ClaudeCodeMascotCard.astro';
---

<BaseLayout
  title="Fitness — Gimbo's Universe"
  description="On the court I am present. The body is the one project I can't delegate — tennis, nutrition, strength, core."
  ogImage="/og-fitness.jpg"
>
  <HeroSection
    name="fitness-hero"
    alt="Fitness — back-view silhouette of a tennis player on an empty terracotta clay court at dusk, racquet at their side"
  />

  <section class="relative">
    <!-- subtle clay band -->
    <div
      class="absolute inset-0 -z-10"
      style="background: linear-gradient(180deg, #0e0f0c 0%, #15110d 60%, #0e0f0c 100%);"
    >
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Modules
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // body × 5
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Tennis · 网球"
          subtitle="Three surfaces — the slam I'm watching right now (currently Roland-Garros), my own training log off-tour (backhand + slice at Koru Club, NTRP 3.5), and a film room of docs and tutorials worth re-watching."
          status="live"
          tools={["Slams", "Training", "Film Room"]}
          href="/fitness/tennis"
          class="lg:col-span-2"
        />
        <ClaudeCodeMascotCard />
        <ModuleCard
          index="02"
          title="Nutrition · 营养"
          subtitle="Mastering the art of healthy eating — a book-club talk turned 27-slide essay. Three lenses on food: nutrition science (CGM self-experiments), aesthetics & pleasure, and belonging."
          status="live"
          tools={["27 slides", "CGM", "Three pillars"]}
          href="/fitness/how-to-eat.html"
        />
        <ModuleCard
          index="03"
          title="Strength · 力量训练"
          subtitle="Compound lifts, mobility work, recovery protocols. Volume tracking and progression as a hedge against everything tennis breaks down."
          status="planned"
          tools={["Apple Health", "Whoop"]}
          href="/fitness/strength"
        />
        <ModuleCard
          index="04"
          title="Core & Stability · 核心与稳定性"
          subtitle="Anti-rotation, anti-extension, single-leg balance. The quiet engine behind every groundstroke and every lift — the part nobody trains until something tears."
          status="planned"
          tools={["Pallof Press", "Dead Bug", "Copenhagen"]}
          href="/fitness/core"
          class="md:col-span-2 lg:col-span-1"
        />
        <ModuleCard
          index="05"
          title="Social Health · 社交健康"
          subtitle="Friendship is health — and it shows up in your body. Notes on the Mel Robbins × Kasley Killam episode: the 5-3-1 formula, the 4 friendship styles, and why loneliness is a vital sign you should track."
          status="live"
          tools={["Mel Robbins Pod", "5-3-1 formula", "Field guide"]}
          href="/fitness/social-health.html"
          class="md:col-span-2 lg:col-span-3"
        />
      </div>
    </div>
  </section>
</BaseLayout>
