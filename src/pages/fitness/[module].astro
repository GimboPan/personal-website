---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import ArticleRow from '~/components/ArticleRow.astro';
import { fitnessModules } from '~/data/fitness';

/* One page per entry in src/data/fitness.ts — /fitness/tennis, /fitness/nutrition, … */
export function getStaticPaths() {
  return fitnessModules.map((m) => ({
    params: { module: m.slug },
    props: { mod: m },
  }));
}

const { mod } = Astro.props;
const { articles } = mod;

const liveCount = articles.filter((a) => a.status === 'live').length;
const wipCount = articles.filter((a) => a.status === 'wip').length;
const planCount = articles.length - liveCount - wipCount;
---

<BaseLayout
  title={mod.meta.title}
  description={mod.meta.description}
  ogImage={mod.meta.ogImage}
>
  <SectionHero
    index={mod.hero.index}
    kicker={mod.hero.kicker}
    title={mod.hero.title}
    subtitle={mod.hero.subtitle}
    bandClass="border-b border-hairline"
  />

  <section class="relative">
    <div class="mx-auto max-w-5xl px-6 lg:px-12 py-14 md:py-20">
      <div class="flex items-end justify-between mb-6 pb-3 border-b border-hairline gap-3">
        <div>
          <div class="terminal text-lime mb-1 text-[10px]">// ARTICLES</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Logs & writing
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
          {liveCount} live · {wipCount} wip · {planCount} planned
        </span>
      </div>

      <div class="space-y-3">
        {articles.map((a) => (
          <ArticleRow
            index={a.index}
            title={a.title}
            lede={a.lede}
            status={a.status}
            href={a.href}
            date={a.date}
            tags={a.tags}
          />
        ))}
      </div>

      <a
        href="/fitness"
        class="mt-10 inline-flex items-center gap-2 font-mono text-[11px] tracking-tool text-ink-gray hover:text-lime transition-colors"
      >
        ← back to Fitness
      </a>
    </div>
  </section>
</BaseLayout>
