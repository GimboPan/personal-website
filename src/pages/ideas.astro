---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';
---

<BaseLayout
  title="Ideas — Gimbo's Universe"
  description="Exploring concepts that shape a better future — humanity, society, technology, and what comes next."
  hideNav={true}
>
  <!-- ============ HERO: full-bleed AI image ============ -->
  <section
    class="relative w-full overflow-hidden border-b border-hairline"
    style="height: min(100vh, calc(100vw * 2 / 3));"
  >
    <img
      src="/landing/ideas-hero.png"
      alt="Ideas — a lone figure stands beneath a giant sculpted head dissolving into floating monoliths above a desert plain"
      class="absolute inset-0 w-full h-full object-cover select-none"
      style="object-position: center top;"
      draggable="false"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Top-nav baked-in text hot spots (mirrors the painted nav inside the image) -->
    <a href="/" aria-label="Gimbo's Universe (home)"
       class="absolute" style="top: 1.5%; left: 1.5%; width: 16%; height: 5%;"></a>
    <a href="/work" aria-label="AI X / Work"
       class="absolute" style="top: 2.5%; left: 60%; width: 6%; height: 3.5%;"></a>
    <a href="/fitness" aria-label="Fitness"
       class="absolute" style="top: 2.5%; left: 67%; width: 7%; height: 3.5%;"></a>
    <a href="/life" aria-label="Life"
       class="absolute" style="top: 2.5%; left: 75%; width: 4%; height: 3.5%;"></a>
    <a href="/ideas" aria-label="Ideas"
       class="absolute" style="top: 2.5%; left: 80%; width: 5%; height: 3.5%;"></a>
    <a href="/about" aria-label="About"
       class="absolute" style="top: 2.5%; left: 86%; width: 6%; height: 3.5%;"></a>
  </section>

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Streams
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // all coming soon · check back later
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Essays"
          subtitle="Long-form pieces — the slow lane. One published when it actually has something to say."
          status="planned"
          tools={["soon"]}
        />
        <ModuleCard
          index="02"
          title="Conviction Theses"
          subtitle="What I think will be true in 5 years and why. Updated when wrong."
          status="planned"
          tools={["soon"]}
        />
        <ModuleCard
          index="03"
          title="Reading Notes"
          subtitle="Notes on books that changed something. Sparse on purpose."
          status="planned"
          tools={["soon"]}
        />
        <ModuleCard
          index="04"
          title="Build Logs"
          subtitle="What the agents did, decided, escalated. Retrospectives from the trenches."
          status="planned"
          tools={["soon"]}
        />
        <ModuleCard
          index="05"
          title="Weekly Reviews"
          subtitle="Six dimensions every Sunday — health, learning, people, projects, money, work."
          status="planned"
          tools={["soon"]}
        />
        <ModuleCard
          index="06"
          title="Sketches"
          subtitle="Half-formed ideas. Posted before they are ready, in case they help someone else."
          status="planned"
          tools={["soon"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
