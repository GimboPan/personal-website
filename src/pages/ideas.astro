---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArticleRow from '~/components/ArticleRow.astro';
import { articles, topicDefs, archiveMonths, seriesDefs } from '~/data/ideas';

// Topic counts + archive timeline are derived from the article list — keeps
// the sidebar numbers honest without a manual update step.
const topics = topicDefs.map((t) => ({
  ...t,
  count:
    t.slug === 'all'
      ? articles.length
      : articles.filter((a) => (a.topics ?? [a.topicSlug]).includes(t.slug))
          .length,
  active: t.slug === 'all',
}));

const archiveCounts = articles.reduce<Record<string, number>>((acc, a) => {
  acc[a.date] = (acc[a.date] ?? 0) + 1;
  return acc;
}, {});
const archive = archiveMonths.map((ym) => ({ ym, count: archiveCounts[ym] ?? 0 }));

// Series (专辑) cards — counts derived from articles, same as topics.
const series = seriesDefs.map((s) => ({
  ...s,
  count: articles.filter((a) => a.seriesSlug === s.slug).length,
}));

// Shared class fragments for the topic filter buttons. JS swaps these on
// click so the active state stays in sync with the live filter.
const TOPIC_BASE =
  'w-full flex items-baseline justify-between gap-3 px-3 py-2 rounded-md text-sm transition-colors border';
const TOPIC_ACTIVE = 'bg-white/[0.04] text-ink-white border-lime/30';
const TOPIC_IDLE =
  'text-ink-mint hover:text-ink-white hover:bg-white/[0.02] border-transparent';
---

<BaseLayout
  title="Ideas — Gimbo's Universe"
  description="Concepts that shape a better future — society, economy, culture, technology."
  ogImage="/og-ideas.jpg"
>
  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16 md:py-20">
      <!-- Page header. A smaller hero image will land in this slot later. -->
      <header class="mb-12 md:mb-16 max-w-2xl">
        <h1 class="font-display text-4xl md:text-6xl font-black text-ink-white leading-none uppercase">
          Ideas.
        </h1>
        <p class="mt-4 md:mt-6 text-base md:text-lg text-ink-mint leading-relaxed">
          Concepts that shape a better future — society, economy, culture, technology. Slow writing, posted when there is something to say.
        </p>
      </header>

      <!-- 3-column layout: topics · articles · archive timeline.
           Stacks on mobile; on desktop the sidebars stay sticky as you scroll.
           Topic + archive controls filter the article list client-side. -->
      <div class="grid grid-cols-1 lg:grid-cols-[180px_minmax(0,1fr)_180px] gap-10 lg:gap-12">

        <!-- LEFT — topic filters -->
        <aside class="lg:sticky lg:top-24 lg:self-start">
          <h2 class="font-mono text-[10px] tracking-tool uppercase text-ink-gray mb-4">
            Topics
          </h2>
          <ul class="flex flex-wrap gap-2 lg:flex-col lg:gap-1">
            {topics.map((t) => (
              <li>
                <button
                  type="button"
                  data-topic-filter={t.slug}
                  aria-pressed={t.active ? 'true' : 'false'}
                  class:list={[TOPIC_BASE, t.active ? TOPIC_ACTIVE : TOPIC_IDLE]}
                >
                  <span class="flex items-baseline gap-2">
                    <span>{t.label}</span>
                    <span class="font-mono text-[10px] tracking-tool text-ink-gray">{t.sub}</span>
                  </span>
                  <span class="font-mono text-[10px] tracking-tool text-ink-gray">{t.count}</span>
                </button>
              </li>
            ))}
          </ul>

          <!-- 专辑 / Series — ongoing threads that cut across topics. Clicking
               filters the list to that series; click again to clear. Counts
               derive from `seriesSlug` on articles. -->
          {series.length > 0 && (
            <>
              <h2 class="font-mono text-[10px] tracking-tool uppercase text-ink-gray mt-8 mb-4">
                Series · 专辑
              </h2>
              <ul class="flex flex-wrap gap-2 lg:flex-col lg:gap-1">
                {series.map((s) => (
                  <li>
                    <button
                      type="button"
                      data-series-filter={s.slug}
                      aria-pressed="false"
                      title={s.description}
                      class:list={[TOPIC_BASE, TOPIC_IDLE]}
                    >
                      <span class="min-w-0 truncate">{s.label}</span>
                      <span class="font-mono text-[10px] tracking-tool text-ink-gray">{s.count}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </>
          )}
        </aside>

        <!-- MIDDLE — article list -->
        <main class="space-y-4">
          {articles.map((a) => (
            <div class="idea-item" data-topic={(a.topics ?? [a.topicSlug]).join(' ')} data-date={a.date} data-series={a.seriesSlug ?? ''}>
              <ArticleRow
                index={a.index}
                title={a.title}
                lede={a.lede}
                date={a.date}
                tags={a.tags}
                status={a.status}
                href={a.href}
                isNew={a.isNew}
                art={a.art}
              />
            </div>
          ))}

          <p id="idea-count" class="font-mono text-[11px] tracking-tool text-ink-gray pt-6">
            // {articles.length} piece{articles.length === 1 ? '' : 's'} · more land here as they finish
          </p>
        </main>

        <!-- RIGHT — archive timeline. Hidden on mobile to keep the article
             column the focus. Months with articles filter the list; empty
             months render as static labels rather than dead links. -->
        <aside class="hidden lg:block lg:sticky lg:top-24 lg:self-start">
          <h2 class="font-mono text-[10px] tracking-tool uppercase text-ink-gray mb-4">
            Archive
          </h2>
          <ul class="space-y-1">
            {archive.map((a) => (
              a.count > 0 ? (
                <li>
                  <button
                    type="button"
                    data-date-filter={a.ym}
                    aria-pressed="false"
                    class="archive-btn w-full flex items-baseline justify-between gap-3 px-3 py-1.5 rounded-md text-sm text-ink-mint hover:text-ink-white hover:bg-white/[0.02] transition-colors"
                  >
                    <span class="font-mono tabular-nums">{a.ym}</span>
                    <span class="font-mono text-[10px] tracking-tool text-ink-gray">{a.count}</span>
                  </button>
                </li>
              ) : (
                <li>
                  <div class="flex items-baseline justify-between gap-3 px-3 py-1.5 text-sm text-ink-gray/50">
                    <span class="font-mono tabular-nums">{a.ym}</span>
                    <span class="font-mono text-[10px] tracking-tool">0</span>
                  </div>
                </li>
              )
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Client-side filtering for /ideas. Topic and month filters combine (AND);
  // clicking an active filter clears it. No framework — plain DOM.
  const TOPIC_ACTIVE = ['bg-white/[0.04]', 'text-ink-white', 'border-lime/30'];
  const TOPIC_IDLE = [
    'text-ink-mint',
    'hover:text-ink-white',
    'hover:bg-white/[0.02]',
    'border-transparent',
  ];

  const items = Array.from(
    document.querySelectorAll<HTMLElement>('.idea-item'),
  );
  const topicBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-topic-filter]'),
  );
  const dateBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-date-filter]'),
  );
  const seriesBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('[data-series-filter]'),
  );
  const countEl = document.getElementById('idea-count');

  let topic = 'all';
  let date = 'all';
  let series = 'all';

  function apply() {
    let shown = 0;
    for (const el of items) {
      const okTopic =
        topic === 'all' ||
        (el.dataset.topic?.split(' ').includes(topic) ?? false);
      const okDate = date === 'all' || el.dataset.date === date;
      const okSeries = series === 'all' || el.dataset.series === series;
      const visible = okTopic && okDate && okSeries;
      el.hidden = !visible;
      if (visible) shown += 1;
    }

    if (countEl) {
      countEl.textContent =
        '// ' +
        shown +
        ' piece' +
        (shown === 1 ? '' : 's') +
        ' · more land here as they finish';
    }

    for (const btn of topicBtns) {
      const on = btn.dataset.topicFilter === topic;
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.remove(...(on ? TOPIC_IDLE : TOPIC_ACTIVE));
      btn.classList.add(...(on ? TOPIC_ACTIVE : TOPIC_IDLE));
    }
    for (const btn of dateBtns) {
      const on = btn.dataset.dateFilter === date;
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.toggle('text-lime', on);
    }
    for (const btn of seriesBtns) {
      const on = btn.dataset.seriesFilter === series;
      btn.setAttribute('aria-pressed', String(on));
      btn.classList.remove(...(on ? TOPIC_IDLE : TOPIC_ACTIVE));
      btn.classList.add(...(on ? TOPIC_ACTIVE : TOPIC_IDLE));
    }
  }

  for (const btn of topicBtns) {
    btn.addEventListener('click', () => {
      topic = btn.dataset.topicFilter ?? 'all';
      apply();
    });
  }
  for (const btn of dateBtns) {
    btn.addEventListener('click', () => {
      const value = btn.dataset.dateFilter ?? 'all';
      date = date === value ? 'all' : value;
      apply();
    });
  }
  for (const btn of seriesBtns) {
    btn.addEventListener('click', () => {
      const value = btn.dataset.seriesFilter ?? 'all';
      series = series === value ? 'all' : value;
      apply();
    });
  }

  apply();
</script>
