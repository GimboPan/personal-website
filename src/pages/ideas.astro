---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';
import HeroSection from '~/components/HeroSection.astro';
---

<BaseLayout
  title="Ideas — Gimbo's Universe"
  description="Exploring concepts that shape a better future — humanity, society, technology, and what comes next."
  ogImage="/og-ideas.jpg"
>
  <HeroSection
    name="ideas-hero"
    alt="Ideas — a lone figure stands beneath a giant sculpted head dissolving into floating monoliths above a desert plain"
  />

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Streams
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // all coming soon · check back later
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Essays"
          subtitle="Long-form pieces — the slow lane. One published when it actually has something to say."
          status="planned"
          tools={[]}
        />
        <ModuleCard
          index="02"
          title="Conviction Theses"
          subtitle="What I think will be true in 5 years and why. Updated when wrong."
          status="planned"
          tools={[]}
        />
        <ModuleCard
          index="03"
          title="Reading Notes"
          subtitle="Notes on books that changed something. Sparse on purpose."
          status="planned"
          tools={[]}
        />
        <ModuleCard
          index="04"
          title="Build Logs"
          subtitle="What the agents did, decided, escalated. Retrospectives from the trenches."
          status="planned"
          tools={[]}
        />
        <ModuleCard
          index="05"
          title="Weekly Reviews"
          subtitle="Six dimensions every Sunday — health, learning, people, projects, money, work."
          status="planned"
          tools={[]}
        />
        <ModuleCard
          index="06"
          title="Sketches"
          subtitle="Half-formed ideas. Posted before they are ready, in case they help someone else."
          status="planned"
          tools={[]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
