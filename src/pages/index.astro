---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';

/**
 * Hot spot positions (% of the hero image, 1536x1024 source).
 * Each island also has a `--depth` for mouse parallax (higher = closer).
 */
const islands = [
  {
    href: '/work',
    label: 'Work',
    style:
      'top: 48%; left: 4%; width: 26%; height: 30%; --float-delay: 0s; --float-dur: 5.5s; --depth: 0.6; --entry-delay: 700ms;',
  },
  {
    href: '/fitness',
    label: 'Fitness',
    style:
      'top: 44%; left: 32%; width: 32%; height: 32%; --float-delay: 0.6s; --float-dur: 6.5s; --depth: 1; --entry-delay: 850ms;',
  },
  {
    href: '/life',
    label: 'Life',
    style:
      'top: 50%; left: 65%; width: 30%; height: 30%; --float-delay: 1.2s; --float-dur: 5s; --depth: 0.7; --entry-delay: 1000ms;',
  },
];

/** Multi-comet meteor shower — each comet has its own CSS-var-driven path. */
const comets = [
  // diagonal NW → SE, primary
  { style: '--ct: 18%; --cl: -14%; --w: 120px; --ang: -14deg; --dur: 14s; --delay: 3s; --tx: 130vw; --ty: 26vh; --hue: rgba(205,255,173,0.95);' },
  // shorter, NE → SW, smaller
  { style: '--ct: 8%; --cl: 110%; --w: 80px; --ang: 195deg; --dur: 19s; --delay: 7s; --tx: -130vw; --ty: 22vh; --hue: rgba(255,220,180,0.85);' },
  // long shallow streak, mid-height
  { style: '--ct: 36%; --cl: -10%; --w: 160px; --ang: -8deg; --dur: 26s; --delay: 11s; --tx: 130vw; --ty: 8vh; --hue: rgba(159,232,112,0.75);' },
  // fast tiny meteor
  { style: '--ct: 24%; --cl: -8%; --w: 60px; --ang: -22deg; --dur: 9s; --delay: 1s; --tx: 130vw; --ty: 35vh; --hue: rgba(255,255,255,0.85);' },
];
---

<BaseLayout
  title="Gimbo's Universe — Work. Invest. Move. Live."
  description="A meaningful life in the future, built one scene at a time. Three floating islands in deep space — work, fitness, life — feeding back into a single virtual identity."
  hideCrt={true}
  hideNav={true}
>
  <!-- ============ HERO: full-bleed AI image ============ -->
  <section
    id="hero"
    class="hero relative w-full overflow-hidden"
    style="height: min(100vh, calc(100vw * 2 / 3));"
  >
    <!-- Background image (parallax: drifts slightly OPPOSITE the cursor).
         Picture element progressively serves AVIF (~65KB) → WebP (~114KB) →
         PNG (~2MB), with smaller responsive variants for narrower viewports. -->
    <picture class="hero-pic absolute inset-0 w-full h-full">
      <source
        type="image/avif"
        srcset="/landing/gimbos-universe-768w.avif 768w, /landing/gimbos-universe-1280w.avif 1280w, /landing/gimbos-universe.avif 1536w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/landing/gimbos-universe-768w.webp 768w, /landing/gimbos-universe-1280w.webp 1280w, /landing/gimbos-universe.webp 1536w"
        sizes="100vw"
      />
      <img
        src="/landing/gimbos-universe.png"
        alt="Gimbo's Universe — three floating islands depicting work, fitness, and life in deep space"
        class="hero-img w-full h-full object-cover select-none"
        style="object-position: center top;"
        draggable="false"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <!-- Subtle starfield twinkle layer -->
    <div class="absolute inset-0 pointer-events-none twinkle-layer"></div>

    <!-- Multi-comet meteor shower -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden comets-layer">
      {comets.map((c) => <span class="comet" style={c.style} />)}
    </div>

    <!-- ─── Click hot spots ─── -->
    <!-- 1. Three island hot spots (parallax wrapper + float inner) -->
    {
      islands.map((it) => (
        <a
          href={it.href}
          aria-label={it.label}
          class="island-hotspot fade-up absolute group"
          style={it.style}
        >
          <span class="sr-only">{it.label}</span>
          <span class="island-floater">
            <span class="island-glow"></span>
            <span class="island-label">
              <span class="terminal text-lime">→ enter</span>
            </span>
          </span>
        </a>
      ))
    }

    <!-- 2. ENTER MY UNIVERSE baked-in button hot spot (top right) -->
    <a
      href="#explore"
      aria-label="Enter my universe"
      class="absolute hotspot-pulse fade-up"
      style="top: 2%; right: 2%; width: 18%; height: 5%; --entry-delay: 350ms;"
    >
      <span class="sr-only">Enter my universe</span>
    </a>

    <!-- 3. Top-nav baked-in text hot spots (6 items: HOME · WORK · FITNESS · LIFE · IDEAS · ABOUT) -->
    <a href="/" aria-label="Gimbo's Universe (home)"
       class="absolute fade-up" style="top: 1.5%; left: 1.5%; width: 16%; height: 5%; --entry-delay: 200ms;"></a>
    <a href="/" aria-label="Home"
       class="absolute fade-up" style="top: 2.5%; left: 22%; width: 5%; height: 3.5%; --entry-delay: 230ms;"></a>
    <a href="/work" aria-label="Work"
       class="absolute fade-up" style="top: 2.5%; left: 28%; width: 5%; height: 3.5%; --entry-delay: 260ms;"></a>
    <a href="/fitness" aria-label="Fitness"
       class="absolute fade-up" style="top: 2.5%; left: 34%; width: 7%; height: 3.5%; --entry-delay: 290ms;"></a>
    <a href="/life" aria-label="Life"
       class="absolute fade-up" style="top: 2.5%; left: 42%; width: 4%; height: 3.5%; --entry-delay: 320ms;"></a>
    <a href="/ideas" aria-label="Ideas"
       class="absolute fade-up" style="top: 2.5%; left: 47%; width: 5%; height: 3.5%; --entry-delay: 350ms;"></a>
    <a href="/about" aria-label="About"
       class="absolute fade-up" style="top: 2.5%; left: 53%; width: 5%; height: 3.5%; --entry-delay: 380ms;"></a>

    <!-- 4. SCROLL TO EXPLORE bottom hot spot -->
    <a
      href="#explore"
      aria-label="Scroll to explore"
      class="absolute scroll-to-explore fade-up"
      style="bottom: 1.5%; left: 50%; transform: translateX(-50%); width: 18%; height: 5%; --entry-delay: 1300ms;"
    >
      <span class="scroll-pulse"></span>
    </a>
  </section>

  <!-- Mouse parallax + debug toggle -->
  <script is:inline>
    (function () {
      const hero = document.getElementById('hero');
      if (!hero) return;

      // Debug toggle
      if (new URLSearchParams(location.search).get('debug') === '1') {
        hero.classList.add('debug-hotspots');
      }

      // Mouse parallax — only on devices with hover (skip touch)
      if (window.matchMedia('(hover: hover)').matches &&
          !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let raf = 0;
        let pendingX = 0;
        let pendingY = 0;

        const apply = () => {
          hero.style.setProperty('--mx', pendingX.toFixed(3));
          hero.style.setProperty('--my', pendingY.toFixed(3));
          raf = 0;
        };

        hero.addEventListener('mousemove', (e) => {
          const rect = hero.getBoundingClientRect();
          pendingX = (e.clientX - rect.left) / rect.width - 0.5;   // -0.5 .. 0.5
          pendingY = (e.clientY - rect.top) / rect.height - 0.5;
          if (!raf) raf = requestAnimationFrame(apply);
        });

        hero.addEventListener('mouseleave', () => {
          pendingX = 0;
          pendingY = 0;
          if (!raf) raf = requestAnimationFrame(apply);
        });
      }
    })();
  </script>

  <!-- ============ EXPLORE: deeper content below the hero ============ -->
  <section id="explore" class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-20 md:py-28">
      <div class="terminal text-lime mb-3 flex items-center gap-2">
        <span>$</span>
        <span>ls -la /universe</span>
      </div>
      <h2 class="display-mega text-ink-white text-3xl sm:text-4xl md:text-5xl lg:text-6xl break-words">
        The working surfaces.
      </h2>
      <p class="mt-5 text-base md:text-lg text-ink-mint max-w-2xl leading-relaxed">
        Each section below is a working surface — projects in flight, notes in
        progress, things I am thinking about right now.
      </p>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Work"
          subtitle="Supply chain agents · investing · AI applications · AI × data analysis. Four working surfaces."
          status="wip"
          href="/work"
          tools={["Claude", "Agents", "Data"]}
          featured={true}
        />
        <ModuleCard
          index="02"
          title="Fitness"
          subtitle="Tennis · nutrition · strength. The body project that won't agentize."
          status="wip"
          href="/fitness"
          tools={["Tennis", "Nutrition", "Strength"]}
        />
        <ModuleCard
          index="03"
          title="Life"
          subtitle="Writing the book · reading · social. The slow lane is the long lane."
          status="wip"
          href="/life"
          tools={["Book", "Reading", "IRL"]}
        />
        <ModuleCard
          index="04"
          title="Ideas"
          subtitle="Half-formed thoughts, essays, conviction theses. Coming soon."
          status="planned"
          href="/ideas"
          tools={["soon"]}
        />
        <ModuleCard
          index="05"
          title="About"
          subtitle="Five roles, one person, ten years in New Zealand. The operator behind the universe."
          status="live"
          href="/about"
          tools={["bio", "creed", "contact"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero defaults ─── */
  .hero {
    --mx: 0;
    --my: 0;
  }

  /* Background image: subtle parallax in the OPPOSITE direction
     (gives a feeling of "I'm moving forward, the universe stays put").
     Scale is small (1.02) + transform-origin top so the painted nav at
     the very top of the source image stays visible after cropping. */
  .hero-img {
    transform:
      translate3d(
        calc(var(--mx) * -10px),
        calc(var(--my) * -6px),
        0
      )
      scale(1.02);
    transform-origin: center top;
    transition: transform 350ms ease-out;
    will-change: transform;
  }

  /* ─── Twinkle layer over image ─── */
  .twinkle-layer {
    background-image:
      radial-gradient(1px 1px at 13% 22%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 27% 14%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 42% 30%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 56% 18%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 71% 24%, #9fe870 50%, transparent 50%),
      radial-gradient(1px 1px at 85% 12%, #ffffff 50%, transparent 50%),
      radial-gradient(1px 1px at 92% 32%, #cdffad 50%, transparent 50%),
      radial-gradient(1px 1px at 8% 8%, #ffffff 50%, transparent 50%);
    background-size: 100% 100%;
    image-rendering: pixelated;
    opacity: 0;
    animation: twinkle-fade 3.5s ease-in-out infinite;
  }

  @keyframes twinkle-fade {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.7; }
  }

  /* ─── Comets (variable-driven) ─── */
  .comet {
    position: absolute;
    top: var(--ct);
    left: var(--cl);
    width: var(--w);
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--hue),
      rgba(159, 232, 112, 0.35),
      transparent
    );
    border-radius: 9999px;
    transform: rotate(var(--ang));
    box-shadow: 0 0 8px rgba(159, 232, 112, 0.5);
    opacity: 0;
    animation: comet-fly var(--dur) ease-in-out infinite;
    animation-delay: var(--delay);
    will-change: transform, opacity;
  }

  @keyframes comet-fly {
    0% {
      transform: translate(0, 0) rotate(var(--ang));
      opacity: 0;
    }
    3%  { opacity: 1; }
    25% {
      transform: translate(var(--tx), var(--ty)) rotate(var(--ang));
      opacity: 0;
    }
    100% {
      transform: translate(var(--tx), var(--ty)) rotate(var(--ang));
      opacity: 0;
    }
  }

  /* ─── Island hot spots: parallax wrapper ─── */
  .island-hotspot {
    border-radius: 32px;
    cursor: pointer;
    /* parallax: shift WITH cursor, scaled by depth */
    transform: translate3d(
      calc(var(--mx, 0) * var(--depth, 1) * 14px),
      calc(var(--my, 0) * var(--depth, 1) * 9px),
      0
    );
    transition: transform 280ms ease-out;
    will-change: transform;
  }

  /* The inner floater carries the bobbing animation so it doesn't
     conflict with the parent's parallax transform. */
  .island-floater {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    animation: island-float var(--float-dur, 5s) ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  @keyframes island-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .island-glow {
    position: absolute;
    inset: -8px;
    border-radius: 36px;
    border: 2px solid transparent;
    transition: border-color 250ms ease, box-shadow 250ms ease;
    pointer-events: none;
  }

  .island-hotspot:hover .island-glow {
    border-color: rgba(159, 232, 112, 0.8);
    box-shadow:
      0 0 24px rgba(159, 232, 112, 0.35),
      inset 0 0 24px rgba(159, 232, 112, 0.15);
  }

  .island-label {
    position: absolute;
    left: 50%;
    bottom: -32px;
    transform: translateX(-50%);
    padding: 4px 10px;
    border-radius: 9999px;
    background: rgba(14, 15, 12, 0.85);
    border: 1px solid rgba(159, 232, 112, 0.6);
    opacity: 0;
    transition: opacity 200ms ease, transform 200ms ease;
    pointer-events: none;
    white-space: nowrap;
  }

  .island-hotspot:hover .island-label {
    opacity: 1;
    transform: translateX(-50%) translateY(-4px);
  }

  /* ─── ENTER MY UNIVERSE pulse ─── */
  .hotspot-pulse {
    border-radius: 9999px;
    transition: transform 200ms ease;
  }
  .hotspot-pulse::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    border: 1px solid transparent;
    transition: border-color 250ms ease, box-shadow 250ms ease;
  }
  .hotspot-pulse:hover::before {
    border-color: rgba(159, 232, 112, 0.7);
    box-shadow: 0 0 16px rgba(159, 232, 112, 0.4);
  }

  /* ─── Scroll-to-explore ─── */
  .scroll-to-explore {
    border-radius: 9999px;
  }
  .scroll-pulse {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: rgba(159, 232, 112, 0);
    animation: scroll-pulse 2.4s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { background: rgba(159, 232, 112, 0); }
    50% { background: rgba(159, 232, 112, 0.08); }
  }

  /* ─── Entry fade-in (opacity only — doesn't touch parallax/float) ─── */
  .fade-up {
    opacity: 0;
    animation: entry-fade 800ms cubic-bezier(0.2, 0.6, 0.3, 1) forwards;
    animation-delay: var(--entry-delay, 0ms);
  }
  /* Image and twinkle/comet layers also fade in as a group */
  .hero-img,
  .twinkle-layer,
  .comets-layer {
    opacity: 0;
    animation: entry-fade 1100ms ease-out 100ms forwards;
  }
  /* keep twinkle's own loop running afterwards via second animation */
  .twinkle-layer {
    animation:
      entry-fade 1100ms ease-out 100ms forwards,
      twinkle-fade 3.5s ease-in-out 1200ms infinite;
  }

  @keyframes entry-fade {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  /* ─── Debug visualization ─── */
  .debug-hotspots a {
    background: rgba(255, 0, 0, 0.15);
    outline: 2px dashed rgba(255, 80, 80, 0.9);
  }
  .debug-hotspots .island-hotspot {
    background: rgba(159, 232, 112, 0.18);
    outline: 2px dashed rgba(159, 232, 112, 0.9);
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .hero-img,
    .island-hotspot,
    .island-floater,
    .twinkle-layer,
    .comet,
    .scroll-pulse,
    .fade-up {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>
