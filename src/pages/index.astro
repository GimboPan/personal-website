---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ModuleCard from '~/components/ModuleCard.astro';
import HeroSection from '~/components/HeroSection.astro';
import PixelMascot from '~/components/PixelMascot.astro';
import { feed, feedUpdated } from '~/data/feed';

// Action word colour by kind — done = shipped/live, wip = in flight, ongoing = steady state.
const actionColor: Record<string, string> = {
  done: 'text-lime',
  wip: 'text-rg-orangeBright',
  ongoing: 'text-ink-gray',
};
---

<BaseLayout
  title="Gimbo's Universe — A life, organised into links."
  description="My digital life OS — work, investing, the body, reading, writing, and life observations in New Zealand, all settling into one shareable place."
  hideCrt={true}
>
  <!-- ============ DISPATCH STRAP: editorial top-line featuring a pinned page.
       Sits between sticky nav and hero — scrolls away with the page. Pure
       typography, no card chrome, intentionally quiet. Currently pinned to the
       Tennis homepage; repoint href + copy below to feature something else. ============ -->
  <div class="relative border-b border-hairline">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
      <a
        href="/fitness/tennis"
        class="group flex items-center gap-3 sm:gap-4 py-2.5 text-[11px] sm:text-xs font-mono tracking-tool"
      >
        <!-- Featured pulse pill -->
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-lime text-canvas font-bold text-[10px] shrink-0">
          <span class="h-1 w-1 rounded-full bg-canvas animate-pulse"></span>
          FEATURED
        </span>

        <!-- Meta — hidden on tiny screens to keep the line breathable -->
        <span class="hidden sm:inline text-ink-gray shrink-0">
          // FITNESS · TENNIS · 网球
        </span>

        <!-- Title — the heart of the message -->
        <span class="text-ink-white font-semibold group-hover:text-lime transition-colors truncate">
          On the court, I am present.
        </span>

        <!-- Subtitle — desktop only, fades into gray -->
        <span class="hidden lg:inline text-ink-gray truncate">
          — 在看什么巡回赛、场下在练什么,以及我一再回去的那间 film room
        </span>

        <!-- Arrow pinned right -->
        <span class="ml-auto text-lime opacity-70 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all shrink-0">
          Read →
        </span>
      </a>
    </div>
  </div>

  <HeroSection
    name="homepage-hero"
    alt="Gimbo's Universe — a sculpted figure dissolving into voxel architecture above an Auckland tennis court at dusk"
    border={false}
  />

  <!-- ============ NOW: the framing line + a reverse-chronological feed of
       what's recently happened across the site. Hand-edited via
       src/data/feed.ts — newest row first. ============ -->
  <section id="now" class="relative border-b border-hairline">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-20 md:py-28">
      <div class="terminal text-lime mb-3">tail -f /universe/log</div>
      <h2 class="display-mega text-ink-white text-3xl sm:text-4xl md:text-5xl lg:text-6xl break-words">
        A life, organised into links.
      </h2>
      <p class="mt-5 text-base md:text-lg text-ink-mint max-w-2xl leading-relaxed">
        Gimbo's Universe is my digital life OS — work, investing, the body,
        reading, writing, and the long observation of a life in New Zealand,
        all settling into one shareable place.
      </p>

      <!-- Recent activity — ordered by time, not by module, so it reads as
           a living log rather than a second copy of the grid below. -->
      <div class="mt-12 max-w-3xl">
        <span class="tool-label">Recent across the universe</span>
        <ul class="mt-4 border-y border-hairline divide-y divide-hairline">
          {feed.map((e) => {
            const Tag = e.href ? 'a' : 'div';
            return (
              <li>
                <Tag
                  href={e.href}
                  class:list={[
                    'group flex items-baseline gap-3 sm:gap-4 py-3',
                    e.href ? '-mx-3 px-3 hover:bg-white/[0.02] transition-colors' : '',
                  ]}
                >
                  <span class="font-mono text-[11px] tabular-nums text-ink-gray shrink-0">
                    {e.date}
                  </span>
                  <span class="flex-1 min-w-0 text-sm leading-relaxed">
                    <span class:list={['font-mono text-[11px] uppercase tracking-tool', actionColor[e.kind]]}>
                      {e.action}
                    </span>
                    <span class="text-ink-gray"> · </span>
                    <span class="text-ink-mint group-hover:text-ink-white transition-colors">
                      {e.title}
                    </span>
                  </span>
                  <span class="font-mono text-[10px] tracking-tool text-ink-gray shrink-0">
                    {e.module}
                  </span>
                  {e.href && (
                    <span class="text-lime opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                      →
                    </span>
                  )}
                </Tag>
              </li>
            );
          })}
        </ul>
        <div class="mt-4 terminal text-ink-gray text-[10px]">
          // {feed.length} updates · {feedUpdated} · edited by hand
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EXPLORE: deeper content below the hero ============ -->
  <section id="explore" class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 pt-20 md:pt-28 pb-0">
      <div class="terminal text-lime mb-3">ls -la /universe</div>
      <h2 class="display-mega text-ink-white text-3xl sm:text-4xl md:text-5xl lg:text-6xl break-words">
        The working surfaces.
      </h2>
      <p class="mt-5 text-base md:text-lg text-ink-mint max-w-2xl leading-relaxed">
        Four modules, each collecting its own long-running threads — work, the body, life, and ideas. Pick a surface and go deeper.
      </p>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <ModuleCard
          index="01"
          title="AI Builder"
          subtitle="Four streams I run from one notebook — agents, investing, applications, analysis."
          status="wip"
          href="/work"
          tools={["Claude", "Agents", "Data"]}
          large={true}
          disableWrapperLink={true}
          class="lg:col-span-2 lg:row-span-2"
        >
          <ul class="mt-6 space-y-1">
            <li>
              <a
                href="/work#supply-chain-agent"
                class="bullet-row group/row"
              >
                <span class="dot bg-rg-orangeBright animate-pulse"></span>
                <span class="bullet-label">Supply Chain Agent</span>
                <span class="bullet-arrow">→</span>
                <span class="bullet-tag text-ink-gray">WIP</span>
              </a>
            </li>
            <li>
              <a
                href="/work/nz-funds.html"
                class="bullet-row group/row"
              >
                <span class="dot bg-lime"></span>
                <span class="bullet-label">Investing &mdash; NZ Funds</span>
                <span class="bullet-arrow">→</span>
                <span class="bullet-tag text-lime">LIVE</span>
              </a>
            </li>
            <li>
              <a
                href="/work#ai-applications"
                class="bullet-row group/row"
              >
                <span class="dot bg-rg-orangeBright animate-pulse"></span>
                <span class="bullet-label">AI Applications</span>
                <span class="bullet-arrow">→</span>
                <span class="bullet-tag text-ink-gray">WIP</span>
              </a>
            </li>
            <li>
              <a
                href="/work#ai-data-analysis"
                class="bullet-row group/row"
              >
                <span class="dot bg-rg-orangeBright animate-pulse"></span>
                <span class="bullet-label">AI &times; Data Analysis</span>
                <span class="bullet-arrow">→</span>
                <span class="bullet-tag text-ink-gray">WIP</span>
              </a>
            </li>
          </ul>

          <!-- Pipeline ghost: placeholder rows for future AI builds.
               Decreasing opacity = "future fades into the haze". -->
          <div class="mt-8 pt-5 border-t border-hairline/50">
            <div class="flex items-center justify-between mb-3">
              <span class="tool-label">In the pipeline</span>
              <span class="terminal text-ink-gray text-[10px]">// more loading</span>
            </div>
            <ul class="space-y-1">
              <li class="bullet-row bullet-row--static opacity-50">
                <span class="dot bg-ink-gray/70"></span>
                <span class="bullet-label font-mono text-ink-gray">&mdash;&mdash;&mdash;&mdash; &mdash;&mdash;&mdash;&mdash;&mdash; &mdash;&mdash;</span>
                <span class="bullet-tag text-ink-gray">SOON</span>
              </li>
              <li class="bullet-row bullet-row--static opacity-40">
                <span class="dot bg-ink-gray/70"></span>
                <span class="bullet-label font-mono text-ink-gray">&mdash;&mdash;&mdash; &mdash;&mdash;&mdash; &mdash;&mdash;&mdash;&mdash;</span>
                <span class="bullet-tag text-ink-gray">SOON</span>
              </li>
              <li class="bullet-row bullet-row--static opacity-30">
                <span class="dot bg-ink-gray/70"></span>
                <span class="bullet-label font-mono text-ink-gray">&mdash;&mdash;&mdash;&mdash; &mdash;&mdash;&mdash;</span>
                <span class="bullet-tag text-ink-gray">TBD</span>
              </li>
              <li class="bullet-row bullet-row--static opacity-20">
                <span class="dot bg-ink-gray/70"></span>
                <span class="bullet-label font-mono text-ink-gray">&mdash;&mdash;&mdash; &mdash;</span>
                <span class="bullet-tag text-ink-gray">TBD</span>
              </li>
            </ul>
          </div>
        </ModuleCard>
        <ModuleCard
          index="02"
          title="Fitness"
          subtitle="Tennis · nutrition · strength. The body project that won't agentize."
          status="wip"
          href="/fitness"
          tools={["Tennis", "Nutrition", "Strength"]}
        >
          <ul class="mt-4 space-y-1">
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-ink-gray"></span>
              <span class="bullet-label">Tennis</span>
              <span class="bullet-tag text-ink-gray">SOON</span>
            </li>
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-ink-gray"></span>
              <span class="bullet-label">Nutrition</span>
              <span class="bullet-tag text-ink-gray">SOON</span>
            </li>
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-ink-gray"></span>
              <span class="bullet-label">Strength</span>
              <span class="bullet-tag text-ink-gray">SOON</span>
            </li>
          </ul>
        </ModuleCard>
        <ModuleCard
          index="03"
          title="Life"
          subtitle="Writing the book · reading · social. The slow lane is the long lane."
          status="wip"
          href="/life"
          tools={["Book", "Reading", "IRL"]}
        >
          <ul class="mt-4 space-y-1">
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-rg-orangeBright animate-pulse"></span>
              <span class="bullet-label">Writing the Book</span>
              <span class="bullet-tag text-ink-gray">WIP</span>
            </li>
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-ink-gray"></span>
              <span class="bullet-label">Reading</span>
              <span class="bullet-tag text-ink-gray">SOON</span>
            </li>
            <li class="bullet-row bullet-row--static">
              <span class="dot bg-ink-gray"></span>
              <span class="bullet-label">Social</span>
              <span class="bullet-tag text-ink-gray">SOON</span>
            </li>
          </ul>
        </ModuleCard>
        <ModuleCard
          index="04"
          title="Ideas"
          subtitle="Essays, conviction theses, and full-book visual guides. Six pieces live and counting."
          status="live"
          href="/ideas"
          tools={[]}
          wide={true}
          class="lg:col-span-2"
        >
          <div class="mt-4 border-t border-hairline pt-4">
            <div class="tool-label mb-2">Latest</div>
            <ul class="space-y-1">
              <li class="bullet-row bullet-row--static">
                <span class="font-mono text-[10px] text-ink-gray w-5">06</span>
                <span class="bullet-label">The Intimate Animal · 全书解读</span>
                <span class="bullet-tag text-lime">LIVE</span>
              </li>
              <li class="bullet-row bullet-row--static">
                <span class="font-mono text-[10px] text-ink-gray w-5">05</span>
                <span class="bullet-label">用 AI Agent 运营一家公司</span>
                <span class="bullet-tag text-lime">LIVE</span>
              </li>
              <li class="bullet-row bullet-row--static">
                <span class="font-mono text-[10px] text-ink-gray w-5">04</span>
                <span class="bullet-label">Open to Work · 全书解读</span>
                <span class="bullet-tag text-lime">LIVE</span>
              </li>
            </ul>
          </div>
        </ModuleCard>
      </div>

      <!-- Bottom dividing line — two pixel companions pacing,
           pausing to look around. Decorative; non-interactive. -->
      <div class="mt-10 md:mt-12">
        <div class="relative h-20 md:h-24 border-b border-hairline">
          <PixelMascot
            size={40}
            walkDuration="48s"
            behavior="snail"
            padding={16}
          />
          <PixelMascot
            size={36}
            walkDuration="55s"
            behavior="snail"
            delay="-22s"
            padding={24}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

