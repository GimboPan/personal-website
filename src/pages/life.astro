---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import ModuleCard from '~/components/ModuleCard.astro';
---

<BaseLayout
  title="Life — Gimbo's Universe"
  description="Writing, reading, and the people in the room — the slow lane."
>
  <SectionHero
    index="03"
    kicker="Scene III — Side profile, books, tea, no laptop"
    title="The slow lane is the long lane."
    subtitle="Three working surfaces — writing a book, reading what doesn't trend, and showing up for the people who matter. The part of the site that resists optimization."
    bandClass="border-b border-hairline"
  />

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Modules
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // slow × 3
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Writing the Book"
          subtitle="《Life Essential in NZ》 — ten years in New Zealand, distilled into nine chapters. Currently writing chapter 3 (finance). Newsletter + ebook when ready."
          status="wip"
          tools={["Markdown", "WeChat MP"]}
          featured={true}
        />
        <ModuleCard
          index="02"
          title="Reading"
          subtitle="What's on the table right now, what changed something, and the long shelf I keep returning to. Sparse on purpose."
          status="planned"
          tools={["Notes", "Markdown"]}
        />
        <ModuleCard
          index="03"
          title="Social"
          subtitle="The dinners, the long walks, the people I owe a call. The most important infrastructure that no app can replace."
          status="planned"
          tools={["IRL"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
