---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CinematicHero from '~/components/CinematicHero.astro';
import { currentlyReading, shelf, groups, talebOverview, talebBooks } from '~/data/life';

// Split the shelf into two tiers once there are enough books to fill both;
// with just a few, keep them together on a single plank.
const shelfTiers =
  shelf.length >= 4
    ? [shelf.slice(0, Math.ceil(shelf.length / 2)), shelf.slice(Math.ceil(shelf.length / 2))]
    : [shelf];
// Organic spine heights (px) so the row never looks like a fence.
const spineHeights = [208, 230, 196, 222, 204, 234, 200, 218, 212, 226];
const spineWidth = (b) => b.spine ?? Math.min(52, Math.max(34, b.title.length * 3 + 26));
---

<BaseLayout
  title="Life — Gimbo's Universe"
  description="Writing the book, reading what doesn't trend, and the people in the room — the slow lane."
  ogImage="/og-life.jpg"
>
  <CinematicHero />

  <!-- ============ MODULE 1 · WRITING THE BOOK ============ -->
  <section id="more" class="relative scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="terminal text-lime mb-1.5 text-[11px]">// chapter 02 published · chapter 03 in flight</div>
      <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white leading-tight">
        Writing the Book
      </h2>

      <a
        href="/life/book"
        class="block group mt-6 card !p-0 overflow-hidden hover:scale-[1.005] transition-transform duration-200"
      >
        <div class="flex flex-col lg:flex-row">
          <!-- Real book cover -->
          <div
            class="lg:w-[40%] flex items-center justify-center px-8 py-10 md:py-12 lg:px-10"
          >
            <img
              src="/bookcover03.png"
              alt="Life Essentials — A Decade of Life in New Zealand · book cover"
              class="w-full max-w-[260px] h-auto rounded-sm shadow-2xl shadow-black/50"
              loading="eager"
              decoding="async"
            />
          </div>
          <!-- Synopsis + CTA -->
          <div class="flex-1 p-7 md:p-9 flex flex-col justify-between">
            <div>
              <div class="font-mono text-[10px] tracking-tool text-ink-gray mb-3">
                9 CHAPTERS · TEN YEARS · ONE QUIET OBSERVATION
              </div>
              <p class="text-base md:text-lg text-ink-mint leading-relaxed">
                Ten years of observation, distilled into nine chapters
                — landing in Auckland, building a career, parsing the
                tax code, eating across two cuisines, and slowly
                re-tuning what "home" means. Not a guide; a slow
                personal record.
              </p>
              <p class="mt-3 text-sm text-ink-gray leading-relaxed">
                Chapter 2 (Food &amp; Health · 饮食与健康) is the first
                one to land publicly. Chapter 3 (Finance · 金融投资)
                is the current draft. Each chapter posts as it lands;
                the full ebook collects them when all nine are in.
              </p>
            </div>
            <div class="mt-6 pt-5 border-t border-hairline flex items-center justify-between">
              <span class="font-mono text-[10px] tracking-tool text-ink-gray">
                Status: 1 published · 2 in flight · 6 outlined
              </span>
              <span class="font-mono text-xs text-lime opacity-70 group-hover:opacity-100 transition-opacity">
                Open table of contents →
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============ MODULE 2 · READING ============ -->
  <section class="relative border-t border-hairline">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// what's on the table right now</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Reading
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
          {currentlyReading.length} now · {shelf.length} on the shelf
        </span>
      </div>

      {/* ── Currently reading: three covers ── */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {currentlyReading.map((b) => (
          <article
            id={b.slug}
            class="reading-card card !p-0 overflow-hidden flex flex-col group transition-all duration-300 ease-out hover:-translate-y-1.5"
          >
            {/* Cover */}
            {b.coverUrl ? (
              <div class="aspect-[2/3] overflow-hidden bg-canvas relative">
                <img
                  src={b.coverUrl}
                  alt={`${b.title} — ${b.author} · book cover`}
                  class="w-full h-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.07]"
                  loading="lazy"
                  decoding="async"
                />
                {/* sheen sweep on hover */}
                <span class="cover-sheen" aria-hidden="true"></span>
              </div>
            ) : (
              <div
                class="aspect-[2/3] flex flex-col items-center justify-center p-5 text-center relative"
                style={`background: linear-gradient(160deg, ${b.hue ?? '#9fe870'}33 0%, #1a1b17 70%); border-bottom: 1px solid ${b.hue ?? '#9fe870'}33;`}
              >
                <div
                  class="font-display text-base md:text-lg font-black uppercase leading-tight tracking-tight"
                  style={`color: ${b.hue ?? '#9fe870'};`}
                >
                  {b.title}
                </div>
                <div class="mt-3 font-mono text-[10px] tracking-tool text-ink-mint">
                  {b.author}
                </div>
              </div>
            )}
            {/* Body */}
            <div class="p-4 flex-1 flex flex-col gap-3">
              <div>
                <h3 class="font-sans text-sm font-black text-ink-white leading-tight">
                  {b.title}
                </h3>
                <div class="mt-0.5 font-mono text-[10px] tracking-tool text-ink-gray">
                  {b.author}
                </div>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {b.tags.map((t) => (
                  <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-lime-tint text-lime tracking-tool">
                    {t}
                  </span>
                ))}
              </div>
              <p class="text-xs text-ink-mint leading-relaxed">
                {b.brief}
              </p>
              <p class="text-xs text-ink-gray italic leading-relaxed border-l border-lime/40 pl-3 mt-auto">
                "{b.thoughts}"
              </p>
            </div>
          </article>
        ))}
      </div>

      {/* ── The virtual shelf: read, spine-out, two tiers on the wall ── */}
      <div class="mt-12 flex items-center gap-3">
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap">// on the shelf · 读过的</span>
        <span class="h-px flex-1 bg-hairline"></span>
      </div>

      <div class="bookshelf mt-5">
        {shelfTiers.map((tier) => (
          <div class="tier">
            <div class="books">
              {tier.map((b, i) => (
                <div
                  class="spine"
                  title={`${b.title} — ${b.author}`}
                  style={`--hue:${b.hue}; height:${spineHeights[i % spineHeights.length]}px; width:${spineWidth(b)}px; color:${b.light ? '#1a1b17' : '#f5f5f0'};`}
                >
                  <span class="spine-title">{b.title}</span>
                  <span class="spine-author">{b.author}</span>
                </div>
              ))}
            </div>
            <div class="board" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MODULE 2.5 · TALEB ZONE ============ -->
  <section id="taleb" class="relative border-t border-hairline scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// read the whole shelf, then drew the map</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            塔勒布专区 · Taleb
          </h2>
          <p class="mt-2 text-sm text-ink-mint leading-relaxed max-w-2xl">
            Nassim Taleb 的 Incerto「不确定性五部曲」。每一本都逐字读透，
            做成一份可视化深读 —— 核心模型、原书故事、关键金句，
            按章节出处标注。给读书会，也给未来的自己。
          </p>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0 hidden sm:block">
          {talebBooks.filter((b) => b.status === 'live').length + 1} / {talebBooks.length + 1} live
        </span>
      </div>

      {/* Featured overview card */}
      <a
        href={talebOverview.href}
        class="block group card !p-0 overflow-hidden hover:scale-[1.005] transition-transform duration-200 mb-4"
        style={`border-color:${talebOverview.hue}33;`}
      >
        <div class="flex flex-col lg:flex-row">
          <div
            class="lg:w-[34%] flex flex-col items-center justify-center px-8 py-9 lg:py-10 text-center"
            style={`background: linear-gradient(160deg, ${talebOverview.hue}1f 0%, #1a1b17 72%);`}
          >
            <div class="font-display text-3xl md:text-4xl font-black uppercase tracking-tight leading-none" style={`color:${talebOverview.hue};`}>
              Incerto
            </div>
            <div class="mt-3 font-mono text-[10px] tracking-tool text-ink-mint">{talebOverview.year} · 5 BOOKS</div>
          </div>
          <div class="flex-1 p-7 md:p-8 flex flex-col justify-between gap-5">
            <div>
              <div class="font-mono text-[10px] tracking-tool text-ink-gray mb-2">{talebOverview.titleEn}</div>
              <h3 class="font-sans text-lg md:text-xl font-black text-ink-white leading-tight">{talebOverview.title}</h3>
              <p class="mt-3 text-sm text-ink-mint leading-relaxed">{talebOverview.thesis}</p>
            </div>
            <div class="pt-4 border-t border-hairline flex items-center justify-between">
              <span class="font-mono text-[10px] tracking-tool text-ink-gray">从这里开始 · start here</span>
              <span class="font-mono text-xs opacity-70 group-hover:opacity-100 transition-opacity" style={`color:${talebOverview.hue};`}>打开总览 →</span>
            </div>
          </div>
        </div>
      </a>

      {/* Five-book grid */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {talebBooks.map((b) => {
          const Tag = b.status === 'live' ? 'a' : 'div';
          return (
            <Tag
              {...(b.status === 'live' ? { href: b.href } : {})}
              class:list={[
                'card !p-0 overflow-hidden flex flex-col group',
                b.status === 'live'
                  ? 'hover:scale-[1.01] transition-transform duration-200'
                  : 'opacity-70',
              ]}
              style={`border-color:${b.hue}26;`}
            >
              {/* Accent header */}
              <div
                class="px-5 pt-5 pb-4 flex items-start justify-between"
                style={`background: linear-gradient(155deg, ${b.hue}1c 0%, transparent 80%); border-bottom:1px solid ${b.hue}22;`}
              >
                <div>
                  <div class="font-display text-3xl font-black leading-none" style={`color:${b.hue};`}>{b.no}</div>
                  <div class="mt-2 font-sans text-base font-black text-ink-white leading-tight">{b.title}</div>
                  <div class="mt-0.5 font-mono text-[10px] tracking-tool text-ink-gray">{b.titleEn} · {b.year}</div>
                </div>
                {b.status === 'wip' && (
                  <span class="font-mono text-[9px] tracking-tool px-2 py-0.5 rounded-full bg-canvas text-ink-gray border border-hairline whitespace-nowrap shrink-0">
                    进行中
                  </span>
                )}
              </div>
              {/* Body */}
              <div class="p-5 flex-1 flex flex-col gap-4">
                <p class="text-xs text-ink-mint leading-relaxed flex-1">{b.thesis}</p>
                <div class="pt-3 border-t border-hairline">
                  {b.status === 'live' ? (
                    <span class="font-mono text-[11px] opacity-70 group-hover:opacity-100 transition-opacity" style={`color:${b.hue};`}>
                      打开可视化 →
                    </span>
                  ) : (
                    <span class="font-mono text-[11px] text-ink-gray">深读进行中…</span>
                  )}
                </div>
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ MODULE 3 · SOCIAL ============ -->
  <section class="relative border-t border-hairline">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// the people in the room</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Social
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
          {groups.length} interest groups
        </span>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {groups.map((g) => (
          <li id={g.slug} class="card flex items-start gap-4">
            <span class="text-3xl shrink-0 leading-none mt-0.5">{g.emoji}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-sans text-base md:text-lg font-black text-ink-white leading-tight">
                  {g.name}
                </h3>
                <span
                  class:list={[
                    'font-mono text-[10px] tracking-tool px-2 py-0.5 rounded-full whitespace-nowrap shrink-0',
                    g.status === 'active'
                      ? 'bg-lime-tint text-lime border border-lime/30'
                      : 'bg-canvas text-ink-gray border border-hairline',
                  ]}
                >
                  {g.status === 'active' ? '● active' : '○ dormant'}
                </span>
              </div>
              <div class="font-mono text-[10px] tracking-tool text-ink-gray mt-1">
                {g.interest} · {g.frequency}
              </div>
              <p class="text-sm text-ink-mint leading-relaxed mt-2">
                {g.brief}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    /* ── Currently-reading cover cards ───────────────────────────────── */
    .reading-card:hover {
      box-shadow:
        0 0 0 1px rgba(159, 232, 112, 0.45),       /* lime ring */
        0 22px 34px -14px rgba(0, 0, 0, 0.8);
    }
    /* A soft diagonal light sweep across the cover on hover */
    .cover-sheen {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(
        115deg,
        transparent 30%,
        rgba(255, 255, 255, 0.18) 48%,
        transparent 64%
      );
      transform: translateX(-120%);
      transition: transform 0.7s ease;
    }
    .group:hover .cover-sheen {
      transform: translateX(120%);
    }
    @media (prefers-reduced-motion: reduce) {
      .reading-card,
      .reading-card:hover { transform: none; }
      .cover-sheen { display: none; }
    }

    /* ── Virtual wall bookshelf ──────────────────────────────────────── */
    .bookshelf {
      display: flex;
      flex-direction: column;
      gap: 34px;
      width: 100%;
      max-width: 440px;   /* a compact wall unit, not a full-width plank */
    }
    .tier { position: relative; }

    /* Row of standing books, sitting on the board below them */
    .books {
      display: flex;
      align-items: flex-end;
      gap: 5px;
      padding: 0 16px;
      min-height: 210px;
    }

    /* A single spine — title at top, author at bottom, read vertically */
    .spine {
      writing-mode: vertical-rl;
      display: flex;
      flex-direction: row;            /* main axis = vertical in this writing mode */
      justify-content: space-between;
      align-items: center;
      padding: 15px 0;
      flex: none;
      border-radius: 3px 3px 1px 1px;
      background:
        linear-gradient(
          to right,
          rgba(255, 255, 255, 0.18) 0%,
          rgba(255, 255, 255, 0.05) 9%,
          transparent 17%,
          transparent 76%,
          rgba(0, 0, 0, 0.26) 92%,
          rgba(0, 0, 0, 0.44) 100%
        ),
        var(--hue);
      box-shadow:
        inset 0 2px 0 rgba(255, 255, 255, 0.22),   /* top page-block highlight */
        0 6px 10px -6px rgba(0, 0, 0, 0.75);
      cursor: default;
      transition:
        transform 0.24s cubic-bezier(0.2, 0.7, 0.3, 1),
        box-shadow 0.24s ease;
    }
    .spine:hover {
      transform: translateY(-14px);
      box-shadow:
        inset 0 2px 0 rgba(255, 255, 255, 0.22),
        0 18px 24px -10px rgba(0, 0, 0, 0.82);
      z-index: 3;
    }
    .spine-title {
      font-weight: 800;
      font-size: 12.5px;
      line-height: 1.05;
      letter-spacing: 0.01em;
      text-shadow: 0 1px 1px rgba(0, 0, 0, 0.25);
      max-height: 78%;
      overflow: hidden;
    }
    .spine-author {
      font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace;
      font-size: 8.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.74;
    }

    /* The plank: a board fixed to the wall, casting a shadow beneath */
    .board {
      height: 15px;
      border-radius: 2px;
      background: linear-gradient(180deg, #2b2c22 0%, #1d1e16 55%, #141509 100%);
      box-shadow:
        inset 0 1px 0 rgba(159, 232, 112, 0.16),   /* lit front edge */
        inset 0 -2px 3px rgba(0, 0, 0, 0.5),
        0 13px 18px -10px rgba(0, 0, 0, 0.85);       /* shadow on the wall */
      position: relative;
    }
    /* Two small mounting brackets under the plank */
    .board::before,
    .board::after {
      content: '';
      position: absolute;
      top: 15px;
      width: 9px;
      height: 11px;
      background: linear-gradient(180deg, #23241c, #15160e);
      border-radius: 0 0 2px 2px;
    }
    .board::before { left: 26px; }
    .board::after { right: 26px; }

    @media (prefers-reduced-motion: reduce) {
      .spine { transition: none; }
      .spine:hover { transform: none; }
    }
  </style>
</BaseLayout>
