---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import ModuleCard from '~/components/ModuleCard.astro';
---

<BaseLayout
  title="Life — Gimbo's Universe"
  description="Books on the table, slow chapters, ten years in NZ."
>
  <SectionHero
    index="03"
    kicker="Scene III — Side profile, books, tea, no laptop"
    title="The slow lane is the long lane."
    subtitle="Ten years in New Zealand, one book in progress, a stack of essays no algorithm will rank. This is the part of the site that resists optimization."
    bandClass="border-b border-hairline"
  />

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Modules
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <ModuleCard
          index="01"
          title="Life Essential in NZ"
          subtitle="The book in progress. 9 chapters; ch.3 (finance) currently writing. Newsletter + ebook."
          status="wip"
          tools={["Markdown", "WeChat MP"]}
          featured={true}
        />
        <ModuleCard
          index="02"
          title="Reading List"
          subtitle="What's currently on the table. Notes when something deserves them."
          status="planned"
          tools={["Markdown"]}
        />
        <ModuleCard
          index="03"
          title="Field Notes"
          subtitle="Short essays, kitchen observations, ten years of small NZ moments."
          status="planned"
          tools={["MDX"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
