---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CinematicHero from '~/components/CinematicHero.astro';
import { currentlyReading, shelf, groups, northStars, talebOverview, talebBooks, screen, podcastLines, podcasts } from '~/data/life';

// Split the shelf into two tiers once there are enough books to fill both;
// with just a few, keep them together on a single plank.
const shelfTiers =
  shelf.length >= 4
    ? [shelf.slice(0, Math.ceil(shelf.length / 2)), shelf.slice(Math.ceil(shelf.length / 2))]
    : [shelf];
// Organic spine heights (px) so the row never looks like a fence.
const spineHeights = [208, 230, 196, 222, 204, 234, 200, 218, 212, 226];
const spineWidth = (b) => b.spine ?? Math.min(52, Math.max(34, b.title.length * 3 + 26));

// Reel & Radio: split films into featured posters and the filmstrip tail.
const featuredScreen = screen.filter((s) => s.featured);
const filmstrip = screen.filter((s) => !s.featured);
const watchedCount = screen.length;
// Podcast hours on 小宇宙 — update as it climbs.
const podcastHours = 326;
const lineHue = (key) => podcastLines.find((l) => l.key === key)?.hue ?? '#9fe870';
const lineLabel = (key) => podcastLines.find((l) => l.key === key)?.label ?? key;
---

<BaseLayout
  title="Life — Gimbo's Universe"
  description="Writing the book, reading what doesn't trend, and the people in the room — the slow lane."
  ogImage="/og-life.jpg"
>
  <CinematicHero />

  <!-- ============ ETHOS · FOUR NORTH STARS ============ -->
  <section id="why" class="relative border-b border-hairline scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-12 md:py-14">
      <div class="terminal text-lime mb-5 text-[11px]">// why all this input · 向内生长</div>
      <ul class="flex flex-wrap gap-2.5 md:gap-3">
        {northStars.map((s) => (
          <li
            class="star inline-flex items-center gap-2.5 rounded-full pl-3.5 pr-4 py-2 transition-transform duration-300 ease-out hover:-translate-y-0.5"
            style={`--hue:${s.hue}; background:${s.hue}1a; border:1px solid ${s.hue}3d;`}
          >
            <span class="w-2 h-2 rounded-full shrink-0" style={`background:${s.hue}; box-shadow:0 0 8px ${s.hue}aa;`}></span>
            <span class="font-display text-base md:text-lg font-black uppercase tracking-tight leading-none" style={`color:${s.hue};`}>{s.en}</span>
            <span class="font-mono text-[10px] tracking-tool text-ink-gray">{s.zh}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ MODULE 1 · WRITING THE BOOK ============ -->
  <section id="more" class="relative scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="terminal text-lime mb-1.5 text-[11px]">// chapter 02 published · chapter 03 in flight</div>
      <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white leading-tight">
        Writing the Book
      </h2>

      <a
        href="/life/book"
        class="block group mt-6 card !p-0 overflow-hidden hover:scale-[1.005] transition-transform duration-200"
      >
        <div class="flex flex-col lg:flex-row">
          <!-- Real book cover -->
          <div
            class="lg:w-[40%] flex items-center justify-center px-8 py-10 md:py-12 lg:px-10"
          >
            <img
              src="/bookcover03.png"
              alt="Life Essentials — A Decade of Life in New Zealand · book cover"
              class="w-full max-w-[260px] h-auto rounded-sm shadow-2xl shadow-black/50"
              loading="eager"
              decoding="async"
            />
          </div>
          <!-- Synopsis + CTA -->
          <div class="flex-1 p-7 md:p-9 flex flex-col justify-between">
            <div>
              <div class="font-mono text-[10px] tracking-tool text-ink-gray mb-3">
                9 CHAPTERS · TEN YEARS · ONE QUIET OBSERVATION
              </div>
              <p class="text-base md:text-lg text-ink-mint leading-relaxed">
                Ten years of observation, distilled into nine chapters
                — landing in Auckland, building a career, parsing the
                tax code, eating across two cuisines, and slowly
                re-tuning what "home" means. Not a guide; a slow
                personal record.
              </p>
              <p class="mt-3 text-sm text-ink-gray leading-relaxed">
                Chapter 2 (Food &amp; Health · 饮食与健康) is the first
                one to land publicly. Chapter 3 (Finance · 金融投资)
                is the current draft. Each chapter posts as it lands;
                the full ebook collects them when all nine are in.
              </p>
            </div>
            <div class="mt-6 pt-5 border-t border-hairline flex items-center justify-between">
              <span class="font-mono text-[10px] tracking-tool text-ink-gray">
                Status: 1 published · 2 in flight · 6 outlined
              </span>
              <span class="font-mono text-xs text-lime opacity-70 group-hover:opacity-100 transition-opacity">
                Open table of contents →
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============ MODULE 2 · READING ============ -->
  <section class="relative border-t border-hairline">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// what's on the table right now</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Reading
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
          {currentlyReading.length} now · {shelf.length} on the shelf
        </span>
      </div>

      {/* ── Currently reading: three covers ── */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {currentlyReading.map((b) => (
          <article
            id={b.slug}
            class="reading-card card !p-0 overflow-hidden flex flex-col group transition-all duration-300 ease-out hover:-translate-y-1.5"
          >
            {/* Cover */}
            {b.coverUrl ? (
              <div class="aspect-[2/3] overflow-hidden bg-canvas relative">
                <img
                  src={b.coverUrl}
                  alt={`${b.title} — ${b.author} · book cover`}
                  class="w-full h-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.07]"
                  loading="lazy"
                  decoding="async"
                />
                {/* sheen sweep on hover */}
                <span class="cover-sheen" aria-hidden="true"></span>
              </div>
            ) : (
              <div
                class="aspect-[2/3] flex flex-col items-center justify-center p-5 text-center relative"
                style={`background: linear-gradient(160deg, ${b.hue ?? '#9fe870'}33 0%, #1a1b17 70%); border-bottom: 1px solid ${b.hue ?? '#9fe870'}33;`}
              >
                <div
                  class="font-display text-base md:text-lg font-black uppercase leading-tight tracking-tight"
                  style={`color: ${b.hue ?? '#9fe870'};`}
                >
                  {b.title}
                </div>
                <div class="mt-3 font-mono text-[10px] tracking-tool text-ink-mint">
                  {b.author}
                </div>
              </div>
            )}
            {/* Body */}
            <div class="p-4 flex-1 flex flex-col gap-3">
              <div>
                <h3 class="font-sans text-sm font-black text-ink-white leading-tight">
                  {b.title}
                </h3>
                <div class="mt-0.5 font-mono text-[10px] tracking-tool text-ink-gray">
                  {b.author}
                </div>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {b.tags.map((t) => (
                  <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-lime-tint text-lime tracking-tool">
                    {t}
                  </span>
                ))}
              </div>
              <p class="text-xs text-ink-mint leading-relaxed">
                {b.brief}
              </p>
              <p class="text-xs text-ink-gray italic leading-relaxed border-l border-lime/40 pl-3 mt-auto">
                "{b.thoughts}"
              </p>
            </div>
          </article>
        ))}
      </div>

      {/* ── Read books (spine-out shelf) + the 塔勒布 专题阅读 panel beside it ── */}
      <div class="mt-12 grid grid-cols-1 lg:grid-cols-[minmax(0,440px)_1fr] gap-10 lg:gap-14 items-start">
        {/* Left · the virtual shelf — read, spine-out, two tiers on the wall */}
        <div>
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap">// on the shelf · 读过的</span>
            <span class="h-px flex-1 bg-hairline"></span>
          </div>
          <div class="bookshelf mt-5">
            {shelfTiers.map((tier) => (
              <div class="tier">
                <div class="books">
                  {tier.map((b, i) => (
                    <div
                      class="spine"
                      title={`${b.title} — ${b.author}`}
                      style={`--hue:${b.hue}; height:${spineHeights[i % spineHeights.length]}px; width:${spineWidth(b)}px; color:${b.light ? '#1a1b17' : '#f5f5f0'};`}
                    >
                      <span class="spine-title">{b.title}</span>
                      <span class="spine-author">{b.author}</span>
                    </div>
                  ))}
                </div>
                <div class="board" aria-hidden="true"></div>
              </div>
            ))}
          </div>
        </div>

        {/* Right · 专题阅读 — the 塔勒布 Incerto deep-read series, collapsed into a list */}
        <div id="taleb" class="scroll-mt-20">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] tracking-tool text-lime whitespace-nowrap">// 专题阅读 · 塔勒布 Incerto</span>
            <span class="h-px flex-1 bg-hairline"></span>
          </div>

          <div class="card !p-0 overflow-hidden mt-5" style={`border-color:${talebOverview.hue}2e;`}>
            {/* Overview band — the way in */}
            <a
              href={talebOverview.href}
              class="block group px-5 py-4 hover:bg-lime-tint/40 transition-colors"
              style={`background: linear-gradient(150deg, ${talebOverview.hue}1c 0%, transparent 70%); border-bottom:1px solid ${talebOverview.hue}26;`}
            >
              <div class="flex items-center justify-between gap-3">
                <div>
                  <div class="font-display text-xl font-black uppercase tracking-tight leading-none" style={`color:${talebOverview.hue};`}>Incerto</div>
                  <div class="mt-1 font-mono text-[10px] tracking-tool text-ink-gray">不确定性五部曲 · {talebOverview.year}</div>
                </div>
                <span class="font-mono text-[11px] opacity-70 group-hover:opacity-100 transition-opacity whitespace-nowrap shrink-0" style={`color:${talebOverview.hue};`}>打开总览 →</span>
              </div>
              <p class="mt-2.5 text-xs text-ink-mint leading-relaxed">
                五本逐字读透后画的可视化深读地图 —— 核心模型、原书故事、关键金句，按章节出处标注。
              </p>
            </a>

            {/* The five books, collapsed into rows */}
            <ul>
              {talebBooks.map((b) => {
                const Tag = b.status === 'live' ? 'a' : 'div';
                return (
                  <li>
                    <Tag
                      {...(b.status === 'live' ? { href: b.href } : {})}
                      title={`${b.title} — ${b.titleEn}`}
                      class:list={[
                        'flex items-center gap-3.5 px-5 py-3 border-t border-hairline group',
                        b.status === 'live' ? 'hover:bg-lime-tint/30 transition-colors' : 'opacity-60',
                      ]}
                    >
                      <span class="font-display text-lg font-black leading-none w-7 shrink-0 text-center" style={`color:${b.hue};`}>{b.no}</span>
                      <span class="flex-1 min-w-0">
                        <span class="block font-sans text-sm font-black text-ink-white leading-tight truncate">{b.title}</span>
                        <span class="block font-mono text-[10px] tracking-tool text-ink-gray truncate">{b.titleEn} · {b.year}</span>
                      </span>
                      {b.status === 'live' ? (
                        <span class="font-mono text-[11px] opacity-70 group-hover:opacity-100 transition-opacity whitespace-nowrap shrink-0" style={`color:${b.hue};`}>打开 →</span>
                      ) : (
                        <span class="font-mono text-[9px] tracking-tool px-2 py-0.5 rounded-full bg-canvas text-ink-gray border border-hairline whitespace-nowrap shrink-0">进行中</span>
                      )}
                    </Tag>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MODULE 2.75 · REEL & RADIO ============ -->
  <section id="reel-radio" class="relative border-t border-hairline scroll-mt-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// watching what doesn't trend · listening on the commute</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Reel &amp; Radio
          </h2>
          <p class="mt-2 text-sm text-ink-mint leading-relaxed max-w-2xl">
            读书之外的另一条输入线：胶片盘里看过的电影与纪录片，
            和下班路上常听的播客 —— 一面「看」，一面「听」。
          </p>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0 hidden sm:block">
          {watchedCount} films · {podcasts.length} shows · {podcastHours}h
        </span>
      </div>

      {/* ── 看 · ON SCREEN ─────────────────────────────────────────── */}
      <div class="flex items-center gap-3 mb-5">
        <span class="font-mono text-[11px] tracking-tool text-lime whitespace-nowrap">◇ 看 · ON SCREEN</span>
        <span class="h-px flex-1 bg-hairline"></span>
      </div>

      {/* Featured posters */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredScreen.map((s) => (
          <article class="reading-card card !p-0 overflow-hidden flex flex-col group transition-all duration-300 ease-out hover:-translate-y-1.5">
            {s.posterUrl ? (
              <div class="aspect-[2/3] overflow-hidden bg-canvas relative">
                <img
                  src={s.posterUrl}
                  alt={`${s.title} — ${s.director} · poster`}
                  class="w-full h-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.07]"
                  loading="lazy"
                  decoding="async"
                />
                <span class="cover-sheen" aria-hidden="true"></span>
              </div>
            ) : (
              <div
                class="aspect-[2/3] flex flex-col items-center justify-center p-5 text-center relative"
                style={`background: linear-gradient(160deg, ${s.hue ?? '#9fe870'}33 0%, #1a1b17 70%); border-bottom: 1px solid ${s.hue ?? '#9fe870'}33;`}
              >
                <div class="font-display text-base md:text-lg font-black uppercase leading-tight tracking-tight" style={`color: ${s.hue ?? '#9fe870'};`}>
                  {s.title}
                </div>
                <div class="mt-3 font-mono text-[10px] tracking-tool text-ink-mint">{s.director}</div>
              </div>
            )}
            <div class="p-4 flex-1 flex flex-col gap-3">
              <div>
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-sans text-sm font-black text-ink-white leading-tight">{s.title}</h3>
                  <span
                    class:list={[
                      'font-mono text-[9px] tracking-tool px-1.5 py-0.5 rounded-full whitespace-nowrap shrink-0 border',
                      s.kind === 'doc' ? 'bg-lime-tint text-lime border-lime/30' : 'bg-canvas text-ink-gray border-hairline',
                    ]}
                  >
                    {s.kind === 'doc' ? 'DOC' : 'FILM'}
                  </span>
                </div>
                <div class="mt-0.5 font-mono text-[10px] tracking-tool text-ink-gray">{s.director} · {s.year}</div>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {s.tags.map((t) => (
                  <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-lime-tint text-lime tracking-tool">{t}</span>
                ))}
              </div>
              <p class="text-xs text-ink-gray italic leading-relaxed border-l border-lime/40 pl-3 mt-auto">"{s.verdict}"</p>
            </div>
          </article>
        ))}
      </div>

      {/* The filmstrip — watched, shown as a roll of frames */}
      {filmstrip.length > 0 && (
        <>
          <div class="mt-12 flex items-center gap-3">
            <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap">// 看过的 · on the reel</span>
            <span class="h-px flex-1 bg-hairline"></span>
          </div>
          <div class="filmstrip mt-5">
            <div class="frames">
              {filmstrip.map((s) => (
                <div class="frame" title={`${s.title} — ${s.director} · ${s.year}`}>
                  <div class="frame-art" style={`background: linear-gradient(155deg, ${s.hue ?? '#9fe870'}40 0%, #14150f 78%);`}>
                    <span class="frame-title" style={`color:${s.hue ?? '#9fe870'};`}>{s.title}</span>
                    <span class="frame-meta">{s.year}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </>
      )}

      {/* ── 听 · ON AIR ────────────────────────────────────────────── */}
      <div class="mt-14 flex items-center gap-3 mb-3">
        <span class="font-mono text-[11px] tracking-tool text-lime whitespace-nowrap inline-flex items-center gap-2">
          <span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          ◇ 听 · ON AIR
        </span>
        <span class="h-px flex-1 bg-hairline"></span>
      </div>

      {/* Taste-line legend */}
      <div class="flex flex-wrap gap-x-4 gap-y-1.5 mb-6">
        {podcastLines.map((l) => (
          <span class="inline-flex items-center gap-1.5 font-mono text-[10px] tracking-tool text-ink-gray">
            <span class="w-2 h-2 rounded-full shrink-0" style={`background:${l.hue};`}></span>
            {l.label}
          </span>
        ))}
      </div>

      {/* Podcast grid — square art */}
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {podcasts.map((p) => (
          <article class="pod-card card !p-0 overflow-hidden flex flex-col group transition-all duration-300 ease-out hover:-translate-y-1" style={`--hue:${p.hue ?? lineHue(p.line)};`}>
            {p.artUrl ? (
              <div class="aspect-square overflow-hidden bg-canvas relative">
                <img src={p.artUrl} alt={`${p.name} · cover`} class="w-full h-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.06]" loading="lazy" decoding="async" />
              </div>
            ) : (
              <div
                class="aspect-square flex flex-col items-center justify-center p-4 text-center relative"
                style={`background: linear-gradient(150deg, ${p.hue ?? lineHue(p.line)}38 0%, #1a1b17 72%); border-bottom: 1px solid ${p.hue ?? lineHue(p.line)}33;`}
              >
                <div class="font-display text-sm md:text-base font-black uppercase leading-tight tracking-tight" style={`color:${p.hue ?? lineHue(p.line)};`}>
                  {p.name}
                </div>
              </div>
            )}
            <div class="p-3.5 flex-1 flex flex-col gap-2">
              <div>
                <h3 class="font-sans text-[13px] font-black text-ink-white leading-tight">{p.name}</h3>
                <div class="mt-0.5 font-mono text-[10px] tracking-tool text-ink-gray truncate">{p.host}</div>
              </div>
              <span class="self-start font-mono text-[9px] tracking-tool px-1.5 py-0.5 rounded-full" style={`background:${lineHue(p.line)}22; color:${lineHue(p.line)};`}>
                {lineLabel(p.line)}
              </span>
              <p class="text-[11px] text-ink-mint leading-relaxed mt-auto">{p.why}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ MODULE 3 · SOCIAL ============ -->
  <section class="relative border-t border-hairline">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex items-end justify-between mb-8 gap-3">
        <div>
          <div class="terminal text-lime mb-1.5 text-[11px]">// the people in the room</div>
          <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
            Social
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
          {groups.length} interest groups
        </span>
      </div>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {groups.map((g) => (
          <li id={g.slug} class="card flex items-start gap-4">
            <span class="text-3xl shrink-0 leading-none mt-0.5">{g.emoji}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-sans text-base md:text-lg font-black text-ink-white leading-tight">
                  {g.name}
                </h3>
                <span
                  class:list={[
                    'font-mono text-[10px] tracking-tool px-2 py-0.5 rounded-full whitespace-nowrap shrink-0',
                    g.status === 'active'
                      ? 'bg-lime-tint text-lime border border-lime/30'
                      : 'bg-canvas text-ink-gray border border-hairline',
                  ]}
                >
                  {g.status === 'active' ? '● active' : '○ dormant'}
                </span>
              </div>
              <div class="font-mono text-[10px] tracking-tool text-ink-gray mt-1">
                {g.interest} · {g.frequency}
              </div>
              <p class="text-sm text-ink-mint leading-relaxed mt-2">
                {g.brief}
              </p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    /* ── North-star cards (ethos band) ───────────────────────────────── */
    .star:hover {
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--hue) 55%, transparent),
        0 18px 28px -14px rgba(0, 0, 0, 0.8);
    }
    @media (prefers-reduced-motion: reduce) {
      .star,
      .star:hover { transform: none; }
    }

    /* ── Currently-reading cover cards ───────────────────────────────── */
    .reading-card:hover {
      box-shadow:
        0 0 0 1px rgba(159, 232, 112, 0.45),       /* lime ring */
        0 22px 34px -14px rgba(0, 0, 0, 0.8);
    }
    /* A soft diagonal light sweep across the cover on hover */
    .cover-sheen {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(
        115deg,
        transparent 30%,
        rgba(255, 255, 255, 0.18) 48%,
        transparent 64%
      );
      transform: translateX(-120%);
      transition: transform 0.7s ease;
    }
    .group:hover .cover-sheen {
      transform: translateX(120%);
    }
