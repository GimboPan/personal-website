---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';

interface Chapter {
  num: string;
  en: string;
  zh: string;
  kicker: string;
  status: 'live' | 'wip' | 'planned';
  slug: string;
  href?: string;          // present only when a chapter page is published
}

/* Real outline — see /Users/gimbo/Desktop/claude cowork/Rewind- 写书/.../OUTLINE.md
   Statuses reflect what's actually drafted (ch02 published, ch03 in flight,
   ch05 has draft v0.1 but no page yet, others outlined only). */
const chapters: Chapter[] = [
  { num: '01', en: 'Sports & Outdoors',                   zh: '运动与户外生活',   kicker: '新西兰教会我的——运动不是自律，是生活本身。',                              status: 'planned', slug: 'sports-outdoors' },
  { num: '02', en: 'Food & Health',                       zh: '饮食与健康',      kicker: '在食物里找到平衡——从中式胃到全球胃。',                                  status: 'live',    slug: 'ch02-food-health', href: '/life/book/ch02-food-health' },
  { num: '03', en: 'Finance & Investing',                 zh: '金融投资',        kicker: '在新西兰学会和钱好好相处。',                                              status: 'wip',     slug: 'finance' },
  { num: '04', en: 'Language & Communication',            zh: '语言与沟通',      kicker: '语言不只是工具，是打开另一个世界的钥匙。',                                 status: 'planned', slug: 'language' },
  { num: '05', en: 'Work & Career',                       zh: '工作与职场',      kicker: '重新理解"工作"这两个字。',                                              status: 'wip',     slug: 'work-career' },
  { num: '06', en: 'Belonging, Social & Community',       zh: '归属感、社交与社区', kicker: '在异国他乡，重新定义"我是谁"和"我属于哪里"。',                       status: 'planned', slug: 'belonging' },
  { num: '07', en: 'Cultural Differences & Adaptation',   zh: '文化差异与适应',   kicker: '差异不是障碍，是看世界的新角度。',                                       status: 'planned', slug: 'culture' },
  { num: '08', en: 'Mental Health & Inner Growth',        zh: '精神健康与内在成长', kicker: '与焦虑共处，找到内在的锚。',                                            status: 'planned', slug: 'mental-health' },
  { num: '09', en: 'TBD',                                 zh: '待定',           kicker: '主题待确定 —— 随着写作推进，灵感会来的。',                              status: 'planned', slug: 'tbd' },
];

const statusMeta = {
  live:    { label: 'LIVE', dot: 'bg-lime',                     text: 'text-lime' },
  wip:     { label: 'WIP',  dot: 'bg-rg-orangeBright animate-pulse', text: 'text-ink-mint' },
  planned: { label: 'PLAN', dot: 'bg-ink-gray',                  text: 'text-ink-gray' },
} as const;

const liveCount = chapters.filter((c) => c.status === 'live').length;
const wipCount = chapters.filter((c) => c.status === 'wip').length;
const planCount = chapters.length - liveCount - wipCount;
---

<BaseLayout
  title="Life Essentials — TOC — Gimbo's Universe"
  description="Table of contents for 《Life Essentials》 — A Decade of Life in New Zealand. Nine chapters from a decade between 2015 and 2025."
>
  <SectionHero
    index="03.1"
    kicker="《Life Essentials》 — A Decade of Life in New Zealand · 2015 – 2025"
    title={['Ten years.', 'Nine chapters.']}
    subtitle="A slow personal record of moving to and settling in New Zealand. One chapter posted at a time, then collected as an ebook when all nine are in."
    bandClass="border-b border-hairline"
  />

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14">
        <!-- Left: synopsis -->
        <aside class="lg:col-span-4 lg:sticky lg:top-24 lg:self-start space-y-6">
          <!-- Cover thumbnail -->
          <img
            src="/bookcover03.png"
            alt="Life Essentials — A Decade of Life in New Zealand · book cover"
            class="w-full max-w-[220px] h-auto rounded-sm shadow-2xl shadow-black/50"
            loading="eager"
            decoding="async"
          />
          <div>
            <div class="terminal text-lime mb-2 text-[10px]">// SYNOPSIS</div>
            <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white leading-tight">
              Why I am writing this.
            </h2>
          </div>
          <p class="text-base text-ink-mint leading-relaxed">
            April Fools' Day, 2015 — I landed in Auckland thinking it
            was a two-year stop. Ten years later I am still here, and
            most of what I learned about this country came from paying
            tax, getting sick, raising kids, and slowly re-tuning what
            "home" feels like.
          </p>
          <p class="text-base text-ink-mint leading-relaxed">
            This book is the version of that decade I would have wanted
            to read before I landed. Not a guide; not a sermon. A
            ten-year personal record, written for myself.
          </p>

          <div class="pt-5 border-t border-hairline space-y-1.5">
            <div class="font-mono text-[10px] tracking-tool text-ink-gray">FORMAT</div>
            <p class="text-sm text-ink-mint leading-relaxed">
              Each chapter posted as it lands. Ebook collects all nine
              when the last one is in.
            </p>
          </div>
          <div class="pt-5 border-t border-hairline space-y-1.5">
            <div class="font-mono text-[10px] tracking-tool text-ink-gray">STATUS</div>
            <p class="text-sm text-ink-mint leading-relaxed">
              {liveCount} live · {wipCount} in flight · {planCount} outlined.
            </p>
          </div>
          <div class="pt-5 border-t border-hairline space-y-1.5">
            <div class="font-mono text-[10px] tracking-tool text-ink-gray">LANGUAGE</div>
            <p class="text-sm text-ink-mint leading-relaxed">
              Bilingual — written primarily in 中文, with English where
              the chapter wants to be read in English.
            </p>
          </div>
          <a
            href="/life"
            class="inline-flex items-center gap-2 font-mono text-[11px] tracking-tool text-ink-gray hover:text-lime transition-colors"
          >
            ← back to Life
          </a>
        </aside>

        <!-- Right: chapter list -->
        <div class="lg:col-span-8">
          <div class="flex items-end justify-between mb-5 pb-3 border-b border-hairline gap-3">
            <div>
              <div class="terminal text-lime mb-1 text-[10px]">// CHAPTERS</div>
              <h2 class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight text-ink-white">
                Table of Contents
              </h2>
            </div>
            <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
              {chapters.length} in total
            </span>
          </div>
          <ul class="space-y-1">
            {chapters.map((c) => {
              const s = statusMeta[c.status];
              const Tag = c.href ? 'a' : 'div';
              return (
                <li id={c.slug} class="scroll-mt-20">
                  <Tag
                    href={c.href}
                    class:list={[
                      'project-row',
                      c.href ? 'project-row--link group/row' : 'project-row--static',
                    ]}
                  >
                    <span class="project-num">{c.num}</span>
                    <span class="project-body">
                      <span class="project-title">
                        {c.en}
                        <span class="ml-2 text-ink-gray font-normal">· {c.zh}</span>
                      </span>
                      <span class="project-summary">{c.kicker}</span>
                    </span>
                    <span class:list={['project-status', s.text]}>
                      <span class:list={['h-1.5 w-1.5 rounded-full', s.dot]} />
                      {s.label}
                    </span>
                    <span class="project-arrow">→</span>
                  </Tag>
                </li>
              );
            })}
          </ul>
          <p class="mt-6 text-sm text-ink-gray leading-relaxed">
            Individual chapter pages come online as each chapter is
            published. Until then, the rows above are the deliberate
            promise list.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
