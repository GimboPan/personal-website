---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroSection from '~/components/HeroSection.astro';
import PixelMascot from '~/components/PixelMascot.astro';
import { projects, categories, type Category, type Project, type CatDef } from '~/data/work';

/* Featured = top 3 by date across all categories. Each category section
   shows up to 3 most-recent items; counts and ordering are derived here
   from the catalog in src/data/work.ts. */
const sortByDate = (a: Project, b: Project) => b.date.localeCompare(a.date);
const featured = [...projects].sort(sortByDate).slice(0, 3);

const catByKey: Record<Category, CatDef> = Object.fromEntries(
  categories.map((c) => [c.key, c]),
) as Record<Category, CatDef>;

const statusMeta = {
  live: { label: 'LIVE', dot: 'bg-lime', text: 'text-lime' },
  wip: { label: 'WIP', dot: 'bg-rg-orangeBright animate-pulse', text: 'text-ink-mint' },
  planned: { label: 'SOON', dot: 'bg-ink-gray', text: 'text-ink-gray' },
  archive: { label: 'ARCHIVE', dot: 'bg-hairline', text: 'text-ink-gray' },
} as const;

const itemsByCategory = (cat: Category) =>
  projects.filter((p) => p.category === cat).sort(sortByDate);
---

<BaseLayout
  title="AI X — Gimbo's Universe"
  description="Building systems that scale human potential. Supply chain agents, investing research, AI experiments — what I'm building this year."
  ogImage="/og-work.jpg"
>
  <HeroSection
    name="work-hero"
    alt="AI X — a sculpted human form fragmenting into voxel architecture, surrounded by orbital schematics on a dark grid"
  />

  <!-- ============ FEATURED · LATEST 3 ============ -->
  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-14 md:py-16">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-2 mb-8">
        <div>
          <div class="terminal text-lime mb-1.5">// most recent · across all streams</div>
          <h2 class="font-display text-3xl md:text-4xl font-black text-ink-white leading-tight">
            Latest builds.
          </h2>
        </div>
        <div class="terminal text-ink-gray text-[11px]">
          {featured.length} of {projects.length} · sorted by date
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {featured.map((p) => {
          const c = catByKey[p.category];
          const s = statusMeta[p.status];
          const Tag = p.href ? 'a' : 'div';
          return (
            <Tag
              href={p.href}
              class:list={[
                'group block card overflow-hidden flex flex-col !p-0',
                p.href ? 'hover:scale-[1.015] transition-transform duration-200' : '',
              ]}
            >
              {/* Image area: gradient + giant monogram + tags */}
              <div
                class="relative aspect-[16/10] flex items-center justify-center overflow-hidden"
                style={`background: ${c.gradient};`}
              >
                {p.imageUrl ? (
                  <img src={p.imageUrl} alt={p.title} class="w-full h-full object-cover" />
                ) : (
                  <span
                    class="font-display font-black select-none pointer-events-none"
                    style={`color: ${c.hue}; opacity: 0.20; font-size: clamp(120px, 30vw, 200px); line-height: 1;`}
                  >
                    {c.monogram}
                  </span>
                )}
                <span
                  class="absolute top-3 left-3 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-mono font-black tracking-tool bg-canvas/75 backdrop-blur-sm"
                  style={`color: ${c.hue}; border: 1px solid ${c.hue}66;`}
                >
                  {c.name}
                </span>
                <span
                  class:list={[
                    'absolute top-3 right-3 inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-black tracking-tool bg-canvas/75 backdrop-blur-sm border border-hairline',
                    s.text,
                  ]}
                >
                  <span class:list={['h-1.5 w-1.5 rounded-full', s.dot]} />
                  {s.label}
                </span>
                <PixelMascot
                  size={36}
                  accent={c.hue}
                  padding={10}
                  bottomOffset={6}
                  walkDuration="11s"
                />
              </div>
              {/* Card body */}
              <div class="p-5 flex-1 flex flex-col">
                <h3 class="font-sans text-lg md:text-xl font-black text-ink-white leading-tight">
                  {p.title}
                </h3>
                <p class="mt-2 text-sm text-ink-mint leading-relaxed flex-1">
                  {p.summary}
                </p>
                <div class="mt-4 pt-3 border-t border-hairline flex items-center justify-between">
                  <span class="font-mono text-[10px] tracking-tool text-ink-gray">
                    {p.date}
                  </span>
                  {p.href && (
                    <span class="font-mono text-xs text-lime opacity-60 group-hover:opacity-100 transition-opacity">
                      → read
                    </span>
                  )}
                </div>
              </div>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ CATEGORIES ============ -->
  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 pb-24 space-y-12">
      {categories.map((cat) => {
        const items = itemsByCategory(cat.key);
        const visible = items.slice(0, 3);
        const hiddenCount = items.length - visible.length;
        return (
          <div id={cat.key} class="scroll-mt-20">
            {/* category header */}
            <div
              class="flex items-end justify-between gap-3 mb-5 pb-3 border-b"
              style={`border-color: ${cat.hue}33;`}
            >
              <div class="min-w-0">
                <div
                  class="terminal text-[11px] mb-1.5 truncate"
                  style={`color: ${cat.hue};`}
                >
                  {cat.kicker}
                </div>
                <h3
                  class="font-display text-2xl md:text-3xl font-black uppercase tracking-tight leading-none"
                  style={`color: ${cat.hue};`}
                >
                  {cat.name}
                </h3>
              </div>
              {hiddenCount > 0 && (
                <span class="font-mono text-[11px] tracking-tool text-ink-gray whitespace-nowrap shrink-0">
                  +{hiddenCount} more
                </span>
              )}
            </div>
            {/* project rows */}
            <ul class="space-y-1">
              {visible.map((p, i) => {
                const s = statusMeta[p.status];
                const Tag = p.href ? 'a' : 'div';
                return (
                  <li>
                    <Tag
                      id={p.slug}
                      href={p.href}
                      class:list={[
                        'project-row group/row',
                        p.href ? 'project-row--link' : 'project-row--static',
                      ]}
                    >
                      <span class="project-num">{String(i + 1).padStart(2, '0')}</span>
                      <span class="project-body">
                        <span class="project-title">{p.title}</span>
                        <span class="project-summary">{p.summary}</span>
                      </span>
                      <span class="project-date">{p.date}</span>
                      <span class:list={['project-status', s.text]}>
                        <span class:list={['h-1.5 w-1.5 rounded-full', s.dot]} />
                        {s.label}
                      </span>
                      <span class="project-arrow">→</span>
                    </Tag>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
