---
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionHero from '~/components/SectionHero.astro';
import ModuleCard from '~/components/ModuleCard.astro';
---

<BaseLayout
  title="AI Builder — Gimbo's Universe"
  description="Supply chain agents, investing, AI applications, AI × data analysis."
>
  <SectionHero
    index="01"
    kicker="Scene I — Empty workstation, two screens still glowing"
    title="The end of work. The start of building."
    subtitle="Four working surfaces — supply chain agents, investing, AI applications, and AI × data analysis. The agents do the running; I do the thinking."
    bandClass="border-b border-hairline"
  />

  <section class="relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-3xl md:text-5xl font-black text-ink-white leading-none">
          Modules
        </h2>
        <div class="terminal text-ink-gray hidden md:block">
          // 4 surfaces · more arriving
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-4">
        <ModuleCard
          id="supply-chain"
          index="01"
          title="Supply Chain Agent"
          subtitle="A three-agent stack running NZ + AU MRP, PO routing, vendor confirmations and settlement. The supervisor agent triages exceptions; I review and approve. Notes, retros, and architecture sketches live here."
          status="wip"
          tools={["Claude", "Python", "MRP"]}
          featured={true}
        />
        <ModuleCard
          id="investing"
          index="02"
          title="Investing"
          subtitle="What I'm putting money behind and why — NZ managed funds, ARK theses, on-chain experiments. Starts with the NZ 华人基金 selection guide."
          status="live"
          href="/work/nz-funds.html"
          tools={["NZ Funds", "PIE/FIF", "ARK"]}
        />
        <ModuleCard
          id="ai-apps"
          index="03"
          title="AI Applications"
          subtitle="Practical agentic workflows I've shipped or am shipping — Outlook rule rewrites, weekly review automation, document parsers. What works in real day-job conditions, not just demos."
          status="planned"
          tools={["Claude SDK", "Skills", "Cron"]}
        />
        <ModuleCard
          id="ai-data"
          index="04"
          title="AI × Data Analysis"
          subtitle="Where AI meets the spreadsheet — vendor performance dashboards, on-chain flow analysis, market structure visualizations. Numbers given a brain."
          status="planned"
          tools={["Python", "Polars", "Chart.js"]}
        />
      </div>
    </div>
  </section>
</BaseLayout>
